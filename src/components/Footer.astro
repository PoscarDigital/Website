---
// Import translations if necessary
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="bg-slate-600 text-white p-8 md:p-12">
  <!-- Container for all footer content -->
  <div class="container mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
    
    <!-- Company Info -->
    <div>
      <h3 class="text-h3 mb-4">POSCAR Digital</h3>
      <p class="text-gray-200 text-caption mb-4">
        {t('footer.description')}
      </p>
      <p class="text-gray-200 text-caption">© {new Date().getFullYear()} POSCAR Digital Co., LTD. All rights reserved.</p>
    </div>

    <!-- Quick Links -->
    <div>
      <h3 class="text-h3 mb-4">{t('footer.quick_links')}</h3>
      <ul class="space-y-3 text-caption">
        <li><a href={`/${lang}`} class="text-gray-200 hover:text-blue-300 transition-colors">{t('nav.home')}</a></li>
        <li><a href={`/${lang}/solutions/`} class="text-gray-200 hover:text-blue-300 transition-colors">{t('nav.products_services')}</a></li>
        <li><a href={`/${lang}/about/`} class="text-gray-200 hover:text-blue-300 transition-colors">{t('nav.about')}</a></li>
        <li><a href={`/${lang}/blogs/`} class="text-gray-200 hover:text-blue-300 transition-colors">{t('nav.blogs')}</a></li>
        <li><a href={`/${lang}/contact/`} class="text-gray-200 hover:text-blue-300 transition-colors">{t('nav.contact_us')}</a></li>
      </ul>
    </div>

    <!-- Contact and Social Media -->
    <div>
      <h3 class="text-h3 mb-4">{t('footer.contact_us')}</h3>
      <ul class="space-y-3 text-gray-200 text-caption">
        <li>{t('footer.phone')}: +855-95-569-568</li>
        <li>{t('footer.email')}: info@poscardigital.com</li>
        <li>{t('footer.address')}: C-7 Building, 6th &amp; 7th Floor, Street Vimean Ahha, Phnom Penh, Cambodia 121001</li>
      </ul>
      <div class="flex space-x-4 mt-6">
        <a href="https://www.facebook.com/poscardigital" target="_blank" rel="noopener noreferrer" class="text-gray-200 hover:text-blue-300 transition-colors"><i class="fab fa-facebook-f"></i></a>
        <a href="https://twitter.com/poscardigital" target="_blank" rel="noopener noreferrer" class="text-gray-200 hover:text-blue-300 transition-colors"><i class="fab fa-twitter"></i></a>
        <a href="https://www.linkedin.com/company/poscardigital" target="_blank" rel="noopener noreferrer" class="text-gray-200 hover:text-blue-300 transition-colors"><i class="fab fa-linkedin-in"></i></a>
        <a href="https://www.instagram.com/poscardigital" target="_blank" rel="noopener noreferrer" class="text-gray-200 hover:text-blue-300 transition-colors"><i class="fab fa-instagram"></i></a>
      </div>
    </div>
  </div>
</footer>