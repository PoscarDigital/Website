---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import LanguagePicker from './LanguagePicker.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="bg-white shadow sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 py-4">
    <nav class="flex justify-between items-center">
      <!-- Logo -->
      <a href={`/${lang}`} class="text-h3 font-bold text-[#C1272D]">POSCAR Digital</a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-8 text-body font-medium text-gray-700">
        <a href={`/${lang}`} class="hover:text-[#991B1F] transition-colors duration-200">{t('nav.home')}</a>
        
        <!-- Solutions Dropdown -->
        <div class="relative group">
          <button class="hover:text-[#991B1F] flex items-center transition-colors duration-200">
            {t('nav.solutions')}
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute left-0 mt-2 w-64 bg-white rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <!-- Education -->
            <div class="p-2">
              <h3 class="text-sm font-semibold text-gray-900 mb-2">{t('nav.education.title')}</h3>
              <a href={`/${lang}/education-sms-solution`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-red-50 hover:text-[#C1272D] rounded transition-colors duration-200">
                {t('nav.education.k12')}
              </a>
              <a href={`/${lang}/education-ums-solution`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-red-50 hover:text-[#C1272D] rounded transition-colors duration-200">
                {t('nav.education.university')}
              </a>
              <a href={`/${lang}/enrollment-online-registration`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-red-50 hover:text-[#C1272D] rounded transition-colors duration-200">
                {t('nav.enterprise.enrollment')}
              </a>
            </div>
            <!-- Enterprise -->
            <div class="p-2 border-t">
              <h3 class="text-sm font-semibold text-gray-900 mb-2">{t('nav.enterprise.title')}</h3>
              <a href={`/${lang}/accounting-erp-vithean`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-red-50 hover:text-[#C1272D] rounded transition-colors duration-200">
                {t('nav.enterprise.accounting')}
              </a>
              <a href={`/${lang}/bakan-elite`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-red-50 hover:text-[#C1272D] rounded transition-colors duration-200">
                {t('nav.enterprise.bakan')}
              </a>
              <a href={`/${lang}/attendance-solution`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-red-50 hover:text-[#C1272D] rounded transition-colors duration-200">
                {t('nav.enterprise.attendance')}
              </a>
              <a href={`/${lang}/hrm-solution`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-red-50 hover:text-[#C1272D] rounded transition-colors duration-200">
                {t('nav.enterprise.hrm')}
              </a>
              <a href={`/${lang}/other-solutions`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-red-50 hover:text-[#C1272D] rounded transition-colors duration-200">
                {t('nav.enterprise.other')}
              </a>
            </div>
          </div>
        </div>

        <a href={`/${lang}#impact`} class="hover:text-[#991B1F] transition-colors duration-200">{t('nav.impact')}</a>
        <a href={`/${lang}#industries`} class="hover:text-[#991B1F] transition-colors duration-200">{t('nav.industries')}</a>
        
        <!-- Company Dropdown -->
        <div class="relative group">
          <button class="hover:text-[#991B1F] flex items-center transition-colors duration-200">
            {t('nav.company.title')}
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute left-0 mt-2 w-48 bg-white rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <a href={`/${lang}/about`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-red-50 hover:text-[#C1272D] rounded transition-colors duration-200">
              {t('nav.company.about')}
            </a>
            <a href={`/${lang}/customers`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-red-50 hover:text-[#C1272D] rounded transition-colors duration-200">
              {t('nav.company.customers')}
            </a>
            <div class="border-t">
              <h3 class="px-4 py-2 text-sm font-semibold text-gray-900">{t('nav.company.legal.title')}</h3>
              <a href={`/${lang}/privacy`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-red-50 hover:text-[#C1272D] rounded transition-colors duration-200">
                {t('nav.company.legal.privacy')}
              </a>
              <a href={`/${lang}/toc`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-red-50 hover:text-[#C1272D] rounded transition-colors duration-200">
                {t('nav.company.legal.terms')}
              </a>
            </div>
          </div>
        </div>

        <a href={`/${lang}/blogs`} class="hover:text-[#991B1F] transition-colors duration-200">{t('nav.blogs')}</a>
        <a href={`/${lang}/contact`} class="hover:text-[#991B1F] transition-colors duration-200">{t('nav.contact')}</a>
      </div>

      <!-- Language Picker -->
      <div class="flex items-center space-x-4">
        <LanguagePicker />
      </div>

      <!-- Mobile Menu Button -->
      <button class="md:hidden text-[#C1272D]" x-data="{ open: false }" @click="open = !open">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>

    <!-- Mobile Navigation -->
    <div class="md:hidden" x-show="open" @click.away="open = false">
      <div class="px-2 pt-2 pb-3 space-y-1">
        <a href={`/${lang}`} class="block px-3 py-2 text-base font-medium text-gray-700 hover:text-[#991B1F] transition-colors duration-200">
          {t('nav.home')}
        </a>
        <a href={`/${lang}/solutions`} class="block px-3 py-2 text-base font-medium text-gray-700 hover:text-[#991B1F] transition-colors duration-200">
          {t('nav.solutions')}
        </a>
        <a href={`/${lang}#impact`} class="block px-3 py-2 text-base font-medium text-gray-700 hover:text-[#991B1F] transition-colors duration-200">
          {t('nav.impact')}
        </a>
        <a href={`/${lang}#industries`} class="block px-3 py-2 text-base font-medium text-gray-700 hover:text-[#991B1F] transition-colors duration-200">
          {t('nav.industries')}
        </a>
        <a href={`/${lang}/about`} class="block px-3 py-2 text-base font-medium text-gray-700 hover:text-[#991B1F] transition-colors duration-200">
          {t('nav.company.about')}
        </a>
        <a href={`/${lang}/customers`} class="block px-3 py-2 text-base font-medium text-gray-700 hover:text-[#991B1F] transition-colors duration-200">
          {t('nav.company.customers')}
        </a>
        <a href={`/${lang}/blogs`} class="block px-3 py-2 text-base font-medium text-gray-700 hover:text-[#991B1F] transition-colors duration-200">
          {t('nav.blogs')}
        </a>
        <a href={`/${lang}/contact`} class="block px-3 py-2 text-base font-medium text-gray-700 hover:text-[#991B1F] transition-colors duration-200">
          {t('nav.contact')}
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  #nav-links {
    display: none;
    opacity: 0;
    transform: translateY(-10px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  #nav-links.visible {
    display: flex;
    opacity: 1;
    transform: translateY(0);
    flex-direction: column;
  }
  @media (min-width: 768px) {
    #nav-links {
      display: flex;
      opacity: 1;
      transform: none;
    }
  }
</style>