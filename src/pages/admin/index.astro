<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>POSCAR Digital - Content Manager</title>
    <link href="/poscar-logo.png" rel="icon" type="image/png" />
    <!-- Include Netlify Identity Widget -->
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    <!-- Include Decap CMS -->
    <script is:inline src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>
    
    <!-- Initialize Identity and CMS -->
    <script is:inline define:vars={{ configPath: '/admin/config.yml' }}>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", user => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });
      }

      // Initialize CMS
      window.CMS_MANUAL_INIT = true;
      window.addEventListener('load', () => {
        window.CMS?.init({ config: { load_config_file: true } });
      });
    </script>
  </body>
</html>
