---
import Base from '../../layouts/Base.astro';
import { getLangFromUrl, useTranslations, getContentTranslations } from '../../i18n/utils';
import { ui } from '../../i18n/ui';

export async function getStaticPaths() {
  return Object.keys(ui).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const content = await getContentTranslations(lang);

// Get translations
const title = content.education.sms.title;
const subtitle = content.education.sms.subtitle;
const operationsTitle = content.education.sms.operations.title;
const operationsItems = content.education.sms.operations.items;
const learningTitle = content.education.sms.learning.title;
const learningItems = content.education.sms.learning.items;
const benefitsTitle = content.education.sms.benefits.title;
const benefits = content.education.sms.benefits.items;
const ctaTitle = content.education.sms.cta.title;
const ctaButton = content.education.sms.cta.button;
---

<Base>
  <!-- Hero Section -->
  <section class="bg-slate-600 text-white py-20 text-center">
    <h1 class="text-4xl font-bold mb-4">{title}</h1>
    <p class="text-lg">{subtitle}</p>
  </section>

  <!-- Overview Features -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 grid md:grid-cols-2 gap-10 text-center">
      <div>
        <h3 class="text-xl font-semibold mb-4">{operationsTitle}</h3>
        <ul class="space-y-2 text-sm text-gray-700 inline-block text-left">
          {Array.isArray(operationsItems) && operationsItems.map((item: string) => (
            <li>• {item}</li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-xl font-semibold mb-4">{learningTitle}</h3>
        <ul class="space-y-2 text-sm text-gray-700 inline-block text-left">
          {Array.isArray(learningItems) && learningItems.map((item: string) => (
            <li>• {item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Promotion Banner -->
  <section class="py-10 text-[#C1272D] text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h3 class="text-3xl font-bold mb-4">Trusted by Schools Nationwide</h3>
      <p class="text-lg mb-6">WikiSchool empowers school leaders, teachers, and parents with real-time data, smart tools, and seamless coordination for student success.</p>
      <img src="/images/wikischool/banner-showcase.jpg" alt="WikiSchool Dashboard Preview" class="mx-auto rounded-lg shadow-xl max-w-full h-auto">
    </div>
  </section>

  <!-- Key Benefits -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h3 class="text-2xl font-bold text-[#C1272D] mb-12">{benefitsTitle}</h3>
      <div class="grid md:grid-cols-3 gap-8">
        {Array.isArray(benefits) && benefits.map((benefit: { title: string; description: string }) => (
          <div>
            <h4 class="font-semibold text-lg mb-2">{benefit.title}</h4>
            <p class="text-sm text-gray-600">{benefit.description}</p>
          </div>
        ))}
      </div>
      <div class="mt-12">
        <a 
          href="https://wikischool.asia" 
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-[#C1272D] text-white px-6 py-3 rounded-full hover:bg-[#991B1F] transition-colors duration-300"
        >
          Visit WikiSchool Website
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 text-center bg-white">
    <h3 class="text-2xl font-bold mb-4">{ctaTitle}</h3>
    <a 
      href={`/${lang}/contact`} 
      class="mt-4 inline-block bg-[#C1272D] text-white px-6 py-3 rounded-full hover:bg-[#991B1F] transition-colors duration-300"
    >
      {ctaButton}
    </a>
  </section>
</Base>