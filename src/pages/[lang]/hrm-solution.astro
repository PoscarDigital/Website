---
import Base from '../../layouts/Base.astro';
import { getLangFromUrl, useTranslations, getContentTranslations } from '../../i18n/utils';
import { ui } from '../../i18n/ui';

export async function getStaticPaths() {
  return Object.keys(ui).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const content = await getContentTranslations(lang);
---

<Base>
  <!-- HRM Solutions Header -->
  <section class="bg-slate-600 text-white py-16 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">HRM Solutions</h1>
      <p class="text-lg md:text-xl mb-8">Comprehensive human resource management system</p>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 bg-white text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto max-w-4xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-gray-50 p-6 rounded-lg">
          <h3 class="text-xl font-semibold mb-4">Employee Management</h3>
          <ul class="space-y-2">
            <li>• Employee Information</li>
            <li>• Attendance Tracking</li>
            <li>• Leave Management</li>
            <li>• Performance Reviews</li>
          </ul>
        </div>
        <div class="bg-gray-50 p-6 rounded-lg">
          <h3 class="text-xl font-semibold mb-4">Payroll & Benefits</h3>
          <ul class="space-y-2">
            <li>• Salary Management</li>
            <li>• Benefits Administration</li>
            <li>• Tax Management</li>
            <li>• Reports Generation</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="py-16 bg-gray-100 text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-bold mb-8">Ready to Streamline Your HR Processes?</h2>
      <a
        href={`/${lang}/contact`}
        class="inline-block bg-slate-600 text-white py-3 px-8 rounded-lg text-lg font-semibold hover:bg-slate-700 transition-colors duration-300"
      >
        {content.common.buttons.contact_us}
      </a>
    </div>
  </section>
</Base>