---
// src/pages/[lang]/product-services.astro
import Base from '../../layouts/Base.astro';
import { getLangFromUrl, useTranslations, getContentTranslations } from '../../i18n/utils';
import { ui } from '../../i18n/ui';

export async function getStaticPaths() {
  return Object.keys(ui).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const content = await getContentTranslations(lang);
---

<Base>
  <!-- Products & Services Header Section -->
  <section class="bg-slate-600 text-white py-16 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">{content.products_services.hero.title}</h1>
      <p class="text-lg md:text-xl mb-8">{content.products_services.hero.description}</p>
    </div>
  </section>

  <!-- Products & Services Details Section -->
  <section class="py-16 bg-white text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto">
      
      <!-- Education Section -->
      <div class="mb-16 text-center">
        <h2 class="text-3xl md:text-4xl font-semibold mb-6">{content.products_services.education.title}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-gray-100 shadow-lg rounded-lg p-6">
            <h3 class="text-2xl font-semibold mb-4">{content.products_services.education.items.k12.title}</h3>
            <p class="text-lg mb-4">{content.products_services.education.items.k12.description}</p>
            <a 
              href="https://wikischool.asia" 
              class="text-blue-600 font-semibold hover:text-blue-400 transition-colors duration-300"
            >
              {content.common.buttons.learn_more}
            </a>
          </div>
          <div class="bg-gray-100 shadow-lg rounded-lg p-6">
            <h3 class="text-2xl font-semibold mb-4">{content.products_services.education.items.university.title}</h3>
            <p class="text-lg mb-4">{content.products_services.education.items.university.description}</p>
            <a 
              href={`/${lang}/education-university`}
              class="text-blue-600 font-semibold hover:text-blue-400 transition-colors duration-300"
            >
              {content.common.buttons.learn_more}
            </a>
          </div>
          <div class="bg-gray-100 shadow-lg rounded-lg p-6">
            <h3 class="text-2xl font-semibold mb-4">{content.products_services.education.items.enrollment.title}</h3>
            <p class="text-lg mb-4">{content.products_services.education.items.enrollment.description}</p>
            <a 
              href={`/${lang}/enrollment-online-registration`}
              class="text-blue-600 font-semibold hover:text-blue-400 transition-colors duration-300"
            >
              {content.common.buttons.learn_more}
            </a>
          </div>
        </div>
      </div>

      <!-- Enterprise Section -->
      <div class="mb-16 text-center">
        <h2 class="text-3xl md:text-4xl font-semibold mb-6">{content.products_services.enterprise.title}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-gray-100 shadow-lg rounded-lg p-6">
            <h3 class="text-2xl font-semibold mb-4">{content.products_services.enterprise.items.vithean.title}</h3>
            <p class="text-lg mb-4">{content.products_services.enterprise.items.vithean.description}</p>
            <a 
              href="https://vithean.com" 
              class="text-blue-600 font-semibold hover:text-blue-400 transition-colors duration-300"
            >
              {content.common.buttons.visit_site}
            </a>
          </div>
          <div class="bg-gray-100 shadow-lg rounded-lg p-6">
            <h3 class="text-2xl font-semibold mb-4">{content.products_services.enterprise.items.attendance.title}</h3>
            <p class="text-lg mb-4">{content.products_services.enterprise.items.attendance.description}</p>
            <a 
              href={`/${lang}/attendance-solution`}
              class="text-blue-600 font-semibold hover:text-blue-400 transition-colors duration-300"
            >
              {content.common.buttons.learn_more}
            </a>
          </div>
          <div class="bg-gray-100 shadow-lg rounded-lg p-6">
            <h3 class="text-2xl font-semibold mb-4">{content.products_services.enterprise.items.hrm.title}</h3>
            <p class="text-lg mb-4">{content.products_services.enterprise.items.hrm.description}</p>
            <a 
              href={`/${lang}/hrm-solution`}
              class="text-blue-600 font-semibold hover:text-blue-400 transition-colors duration-300"
            >
              {content.common.buttons.learn_more}
            </a>
          </div>
        </div>
      </div>

      <!-- Custom Solution Section -->
      <div class="mb-16 text-center">
        <h2 class="text-3xl md:text-4xl font-semibold mb-6">{content.products_services.custom_solution.title}</h2>
        <div class="grid grid-cols-1 md:grid-cols-1 lg:grid-cols-1 gap-8">
          <div class="bg-gray-100 shadow-lg rounded-lg p-6">
            <h3 class="text-2xl font-semibold mb-4">{content.products_services.custom_solution.items.tailored.title}</h3>
            <p class="text-lg mb-4">{content.products_services.custom_solution.items.tailored.description}</p>
            <a 
              href={`/${lang}/custom-solutions`}
              class="text-blue-600 font-semibold hover:text-blue-400 transition-colors duration-300"
            >
              {content.common.buttons.learn_more}
            </a>
          </div>
        </div>
      </div>

      <!-- Outsourcing Section -->
      <div class="text-center">
        <h2 class="text-3xl md:text-4xl font-semibold mb-6">{content.products_services.outsourcing.title}</h2>
        <div class="grid grid-cols-1 md:grid-cols-1 lg:grid-cols-1 gap-8">
          <div class="bg-gray-100 shadow-lg rounded-lg p-6">
            <h3 class="text-2xl font-semibold mb-4">{content.products_services.outsourcing.items.services.title}</h3>
            <p class="text-lg mb-4">{content.products_services.outsourcing.items.services.description}</p>
            <a 
              href={`/${lang}/outsourcing`}
              class="text-blue-600 font-semibold hover:text-blue-400 transition-colors duration-300"
            >
              {content.common.buttons.learn_more}
            </a>
          </div>
        </div>
      </div>

    </div>
  </section>
</Base>