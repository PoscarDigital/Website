---
import Base from '../../layouts/Base.astro';
import { getLangFromUrl, useTranslations, getContentTranslations } from '../../i18n/utils';
import { ui } from '../../i18n/ui';

export async function getStaticPaths() {
  return Object.keys(ui).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const content = await getContentTranslations(lang);

// Get translations
const title = content.enrollment.title;
const subtitle = content.enrollment.subtitle;
const operationsTitle = content.enrollment.operations.title;
const operationsItems = content.enrollment.operations.items;
const learningTitle = content.enrollment.learning.title;
const learningItems = content.enrollment.learning.items;
const benefitsTitle = content.enrollment.benefits.title;
const benefits = content.enrollment.benefits.items;
const ctaTitle = content.enrollment.cta.title;
const ctaButton = content.enrollment.cta.button;

const enterpriseCategory = await t('nav.enterprise.title');
---

<Base title={title} description={subtitle}>
  <!-- Hero Section: split layout -->
  <section class="relative overflow-hidden bg-gradient-to-b from-red-50 to-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="text-center md:text-left">
          <p class="eyebrow mb-5">{enterpriseCategory}</p>
          <h1 class="text-display text-[#C1272D] mb-6">{title}</h1>
          <p class="text-lead text-gray-700 mb-8 max-w-xl mx-auto md:mx-0">
            {subtitle}
          </p>
          <div class="flex flex-wrap gap-4 justify-center md:justify-start">
            <a href={`/${lang}/contact`} class="btn btn-primary">
              {ctaButton}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
        <div class="relative isolate aspect-square max-w-md mx-auto md:ml-auto">
          <div class="absolute -top-8 -left-8 w-64 h-64 bg-[#C1272D]/20 rounded-full blur-3xl z-0" aria-hidden="true"></div>
          <div class="absolute -bottom-8 -right-8 w-64 h-64 bg-orange-300/20 rounded-full blur-3xl z-0" aria-hidden="true"></div>
          <div class="relative z-10 h-full bg-white rounded-3xl shadow-2xl ring-1 ring-red-100 flex items-center justify-center">
            <svg class="w-32 h-32 text-[#C1272D]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview Features: two card columns -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-8">
        <div class="card-lift bg-white border border-gray-200 rounded-xl p-8 shadow-md hover:shadow-xl">
          <div class="w-12 h-12 rounded-full bg-[#C1272D]/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-[#C1272D]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
          <h2 class="text-h2 mb-4 text-[#C1272D]">{operationsTitle}</h2>
          <ul class="space-y-3 text-body text-gray-700">
            {Array.isArray(operationsItems) && operationsItems.map((item: string) => (
              <li class="flex items-start">
                <svg class="w-5 h-5 mr-3 mt-0.5 text-[#C1272D] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="card-lift bg-white border border-gray-200 rounded-xl p-8 shadow-md hover:shadow-xl">
          <div class="w-12 h-12 rounded-full bg-[#C1272D]/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-[#C1272D]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h2 class="text-h2 mb-4 text-[#C1272D]">{learningTitle}</h2>
          <ul class="space-y-3 text-body text-gray-700">
            {Array.isArray(learningItems) && learningItems.map((item: string) => (
              <li class="flex items-start">
                <svg class="w-5 h-5 mr-3 mt-0.5 text-[#C1272D] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Benefits -->
  <section class="py-20 bg-gray-50 border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h2 class="text-h1 text-[#C1272D] mb-14">{benefitsTitle}</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {Array.isArray(benefits) && benefits.map((benefit: { title: string; description: string }) => (
          <div class="card-lift bg-white border border-gray-200 rounded-xl p-8 shadow-sm hover:shadow-lg text-center">
            <div class="w-14 h-14 mx-auto mb-5 rounded-full bg-[#C1272D]/10 flex items-center justify-center">
              <svg class="w-7 h-7 text-[#C1272D]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-h3 mb-3 text-gray-900">{benefit.title}</h3>
            <p class="text-body text-gray-600">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 text-center bg-red-50 border-t border-red-100">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-h1 text-[#C1272D] mb-6">{ctaTitle}</h2>
      <a href={`/${lang}/contact`} class="btn btn-primary">
        {ctaButton}
      </a>
    </div>
  </section>
</Base>
