---
// src/pages/[lang]/bakan-elite.astro
import Base from '../../layouts/Base.astro';
import { getLangFromUrl, useTranslations, getContentTranslations } from '../../i18n/utils';
import { ui } from '../../i18n/ui';

export async function getStaticPaths() {
  return Object.keys(ui).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const content = await getContentTranslations(lang);

const title = content.bakan.title;
const subtitle = content.bakan.subtitle;
const operationsTitle = content.bakan.operations.title;
const operationsItems = content.bakan.operations.items;
const learningTitle = content.bakan.learning.title;
const learningItems = content.bakan.learning.items;
const benefitsTitle = content.bakan.benefits.title;
const benefits = content.bakan.benefits.items;
const ctaTitle = content.bakan.cta.title;
const ctaButton = content.bakan.cta.button;
const websiteUrl = content.bakan.website.url;
const websiteButton = content.bakan.website.button;

const enterpriseCategory = await t('nav.enterprise.title');
---

<Base title={title} description={subtitle}>
  <!-- Hero Section: split layout -->
  <section class="relative overflow-hidden bg-slate-700 text-white py-16 md:py-24">
    <div class="absolute inset-0 bg-gradient-to-br from-slate-700 to-slate-900" aria-hidden="true"></div>
    <div class="relative max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="text-center md:text-left">
          <p class="eyebrow-light mb-5">{enterpriseCategory}</p>
          <h1 class="text-display mb-6">{title}</h1>
          <p class="text-lead text-slate-200 mb-8 max-w-xl mx-auto md:mx-0">
            {subtitle}
          </p>
          <div class="flex flex-wrap gap-4 justify-center md:justify-start">
            <a href={`/${lang}/contact`} class="btn btn-primary">
              {ctaButton}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a
              href={websiteUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-secondary"
            >
              {websiteButton}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>
        <div class="relative">
          <div class="absolute -inset-6 bg-[#C1272D]/20 rounded-3xl blur-2xl" aria-hidden="true"></div>
          <img
            src="/images/bakan-elite.png"
            alt={title}
            class="relative w-full rounded-2xl shadow-2xl ring-1 ring-white/10"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Overview Features: two card columns -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-8">
        <div class="card-lift bg-white border border-gray-200 rounded-xl p-8 shadow-md hover:shadow-xl">
          <div class="w-12 h-12 rounded-full bg-[#C1272D]/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-[#C1272D]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
            </svg>
          </div>
          <h2 class="text-h2 mb-4 text-[#C1272D]">{operationsTitle}</h2>
          <ul class="space-y-3 text-body text-gray-700">
            {operationsItems.map((item: string) => (
              <li class="flex items-start">
                <svg class="w-5 h-5 mr-3 mt-0.5 text-[#C1272D] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="card-lift bg-white border border-gray-200 rounded-xl p-8 shadow-md hover:shadow-xl">
          <div class="w-12 h-12 rounded-full bg-[#C1272D]/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-[#C1272D]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h2 class="text-h2 mb-4 text-[#C1272D]">{learningTitle}</h2>
          <ul class="space-y-3 text-body text-gray-700">
            {learningItems.map((item: string) => (
              <li class="flex items-start">
                <svg class="w-5 h-5 mr-3 mt-0.5 text-[#C1272D] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Benefits -->
  <section class="py-20 bg-gray-50 border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h2 class="text-h1 text-[#C1272D] mb-14">{benefitsTitle}</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {benefits.map((benefit: { title: string; description: string }) => (
          <div class="card-lift bg-white border border-gray-200 rounded-xl p-8 shadow-sm hover:shadow-lg text-center">
            <div class="w-14 h-14 mx-auto mb-5 rounded-full bg-[#C1272D]/10 flex items-center justify-center">
              <svg class="w-7 h-7 text-[#C1272D]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-h3 mb-3 text-gray-900">{benefit.title}</h3>
            <p class="text-body text-gray-600">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 text-center bg-red-50 border-t border-red-100">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-h1 text-[#C1272D] mb-6">{ctaTitle}</h2>
      <a href={`/${lang}/contact`} class="btn btn-primary">
        {ctaButton}
      </a>
    </div>
  </section>
</Base>
