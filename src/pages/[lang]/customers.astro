---
import Base from '../../layouts/Base.astro';
import { getLangFromUrl, useTranslations, getContentTranslations } from '../../i18n/utils';
import { ui } from '../../i18n/ui';

export async function getStaticPaths() {
  return Object.keys(ui).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const content = await getContentTranslations(lang);
---

<Base>
  <!-- Customers Header -->
  <section class="bg-slate-600 text-white py-16 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Our Customers</h1>
      <p class="text-lg md:text-xl mb-8">Trusted by leading organizations across Cambodia</p>
    </div>
  </section>

  <!-- Featured Customers -->
  <section class="py-16 bg-white text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto max-w-6xl">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
        <!-- Customer Logo 1 -->
        <div class="flex items-center justify-center p-6 bg-gray-50 rounded-lg">
          <img src="/images/customer-1.png" alt="Customer 1" class="max-h-16" />
        </div>
        <!-- Customer Logo 2 -->
        <div class="flex items-center justify-center p-6 bg-gray-50 rounded-lg">
          <img src="/images/customer-2.png" alt="Customer 2" class="max-h-16" />
        </div>
        <!-- Customer Logo 3 -->
        <div class="flex items-center justify-center p-6 bg-gray-50 rounded-lg">
          <img src="/images/customer-3.png" alt="Customer 3" class="max-h-16" />
        </div>
        <!-- Customer Logo 4 -->
        <div class="flex items-center justify-center p-6 bg-gray-50 rounded-lg">
          <img src="/images/customer-4.png" alt="Customer 4" class="max-h-16" />
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 bg-gray-100 text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto max-w-4xl">
      <h2 class="text-3xl font-bold text-center mb-12">What Our Customers Say</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Testimonial 1 -->
        <div class="bg-white p-6 rounded-lg shadow-md">
          <p class="text-gray-600 mb-4">
            "POSCAR's solutions have transformed our educational institution. The system is intuitive and has greatly
            improved our administrative efficiency."
          </p>
          <div class="flex items-center">
            <img src="/images/testimonial-1.jpg" alt="Testimonial 1" class="w-12 h-12 rounded-full mr-4" />
            <div>
              <h4 class="font-semibold">John Doe</h4>
              <p class="text-sm text-gray-500">School Director</p>
            </div>
          </div>
        </div>
        <!-- Testimonial 2 -->
        <div class="bg-white p-6 rounded-lg shadow-md">
          <p class="text-gray-600 mb-4">
            "The HRM solution has streamlined our HR processes and made employee management much more efficient. Highly
            recommended!"
          </p>
          <div class="flex items-center">
            <img src="/images/testimonial-2.jpg" alt="Testimonial 2" class="w-12 h-12 rounded-full mr-4" />
            <div>
              <h4 class="font-semibold">Jane Smith</h4>
              <p class="text-sm text-gray-500">HR Manager</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="py-16 bg-white text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-bold mb-8">Join Our Growing Customer Base</h2>
      <a
        href={`/${lang}/contact`}
        class="inline-block bg-slate-600 text-white py-3 px-8 rounded-lg text-lg font-semibold hover:bg-slate-700 transition-colors duration-300"
      >
        {content.common.buttons.contact_us}
      </a>
    </div>
  </section>
</Base>