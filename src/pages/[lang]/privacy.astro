---
// src/pages/[lang]/privacy.astro
import Base from '../../layouts/Base.astro';
import { getLangFromUrl, useTranslations, getContentTranslations } from '../../i18n/utils';
import { ui } from '../../i18n/ui';

export async function getStaticPaths() {
  return Object.keys(ui).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const content = await getContentTranslations(lang);
---

<Base>
  <!-- Privacy Policy Header -->
  <section class="bg-slate-600 text-white py-16 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">{content.privacy.title}</h1>
      <p class="text-lg md:text-xl mb-8">{content.privacy.last_updated}</p>
    </div>
  </section>

  <!-- Privacy Policy Content -->
  <section class="py-16 bg-white text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto max-w-4xl">
      <div class="prose prose-lg mx-auto">
        <h2>1. {content.privacy.sections.introduction.title}</h2>
        <p>{content.privacy.sections.introduction.content}</p>

        <h2>2. {content.privacy.sections.info_collection.title}</h2>
        <p>{content.privacy.sections.info_collection.content}</p>
        <ul>
          {(content.privacy.sections.info_collection.list || []).map((item: string) => <li>{item}</li>)}
        </ul>

        <h2>3. {content.privacy.sections.usage.title}</h2>
        <p>{content.privacy.sections.usage.content}</p>
        <ul>
          {(content.privacy.sections.usage.list || []).map((item: string) => <li>{item}</li>)}
      </ul>

        <h2>4. {content.privacy.sections.sharing.title}</h2>
        <p>{content.privacy.sections.sharing.content}</p>
        <ul>
          {(content.privacy.sections.sharing.list || []).map((item: string) => <li>{item}</li>)}
      </ul>

        <h2>5. {content.privacy.sections.security.title}</h2>
        <p>{content.privacy.sections.security.content}</p>

        <h2>6. {content.privacy.sections.rights.title}</h2>
        <p>{content.privacy.sections.rights.content}</p>
        <ul>
          {(content.privacy.sections.rights.list || []).map((item: string) => <li>{item}</li>)}
      </ul>

        <h2>7. {content.privacy.sections.contact.title}</h2>
        <p>{content.privacy.sections.contact.content}</p>
      </div>
    </div>
  </section>
</Base>
