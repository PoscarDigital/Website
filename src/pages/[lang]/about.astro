---
import Base from '../../layouts/Base.astro';
import { getLangFromUrl, useTranslations, getContentTranslations } from '../../i18n/utils';
import { ui } from '../../i18n/ui';

export async function getStaticPaths() {
  return Object.keys(ui).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const content = await getContentTranslations(lang);
const a = content.about;

const meta = {
  title: 'About POSCAR Digital - Leading Digital Solutions Provider in Cambodia',
  description: 'Learn about POSCAR Digital, a leading provider of smart education, accounting, attendance, and ERP solutions in Cambodia. Discover our mission, vision, and innovative digital platforms including Wiki School and Vithean.',
  keywords: 'POSCAR Digital, company profile, about us, digital solutions, Cambodia, Wiki School, Vithean, ERP solutions, smart education, accounting software',
  ogImage: '/images/poscar-digital-about.jpg'
};

const techIcons = [
  // server
  'M5 12h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12a2 2 0 100 4h14a2 2 0 100-4m-2-4h.01M17 16h.01',
  // cloud
  'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z',
  // building (national)
  'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  // shield-check
  'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
];
---

<Base meta={meta}>
  <!-- Hero: split, light gradient -->
  <section class="relative overflow-hidden bg-gradient-to-b from-red-50 to-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="text-center md:text-left">
          <p class="eyebrow mb-5">{a.hero.eyebrow}</p>
          <h1 class="text-display text-[#C1272D] mb-6">{a.hero.title}</h1>
          <p class="text-lead text-gray-700 mb-8 max-w-xl mx-auto md:mx-0">
            {a.hero.description}
          </p>
          <div class="flex flex-wrap gap-4 justify-center md:justify-start">
            <a href={`/${lang}/contact`} class="btn btn-primary">
              {a.hero.primary_cta}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a href={`/${lang}/solutions`} class="btn btn-secondary">{a.hero.secondary_cta}</a>
          </div>
        </div>
        <div class="relative isolate">
          <div class="absolute -inset-6 bg-[#C1272D]/10 rounded-3xl blur-2xl z-0" aria-hidden="true"></div>
          <img
            src="/images/office/meeting.jpg"
            alt="Inside the POSCAR Digital office in Phnom Penh"
            class="relative z-10 w-full rounded-2xl shadow-2xl ring-1 ring-red-100 object-cover aspect-[4/3]"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section aria-label="POSCAR by the numbers" class="bg-white border-y border-gray-100 py-12">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {a.stats.items.map((stat: { value: string; label: string }) => (
          <div>
            <div class="text-stat text-[#C1272D] mb-2">{stat.value}</div>
            <p class="text-caption text-gray-600 uppercase tracking-wider">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Company Profile -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="card-lift bg-white border border-gray-200 rounded-xl shadow-md hover:shadow-xl p-10">
        <h2 class="text-h1 text-[#C1272D] mb-6">{a.profile.title}</h2>
        <p class="text-lead text-gray-700">
          {a.profile.description}
        </p>
      </div>
    </div>
  </section>

  <!-- Our Story / Timeline -->
  <section class="py-20 bg-gray-50 border-t border-gray-100">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-14">
        <h2 class="text-h1 text-[#C1272D] mb-4">{a.story.title}</h2>
        <p class="text-lead text-gray-600">{a.story.description}</p>
      </div>
      <ol class="relative border-l-2 border-[#C1272D]/20 ml-4 md:ml-8 space-y-10">
        {a.story.timeline.map((event: { year: string; title: string; description: string }) => (
          <li class="pl-8 md:pl-12 relative">
            <span class="absolute -left-3 top-1 w-6 h-6 rounded-full bg-[#C1272D] ring-4 ring-red-50 flex items-center justify-center" aria-hidden="true">
              <span class="w-2 h-2 rounded-full bg-white"></span>
            </span>
            <p class="text-caption font-bold text-[#C1272D] tracking-wider mb-1">{event.year}</p>
            <h3 class="text-h3 text-gray-900 mb-2">{event.title}</h3>
            <p class="text-body text-gray-700">{event.description}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Vision + Mission (side-by-side) -->
  <section class="py-20 bg-white border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-4 grid md:grid-cols-2 gap-8">
      <div class="card-lift bg-white border border-gray-200 shadow-md hover:shadow-xl rounded-xl p-10">
        <div class="w-12 h-12 rounded-full bg-[#C1272D]/10 flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-[#C1272D]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
        </div>
        <h2 class="text-h2 text-[#C1272D] mb-4">{a.vision.title}</h2>
        <p class="text-body text-gray-700 leading-relaxed">{a.vision.description}</p>
      </div>
      <div class="card-lift bg-white border border-gray-200 shadow-md hover:shadow-xl rounded-xl p-10">
        <div class="w-12 h-12 rounded-full bg-[#C1272D]/10 flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-[#C1272D]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h2 class="text-h2 text-[#C1272D] mb-4">{a.mission.title}</h2>
        <p class="text-body text-gray-700 leading-relaxed">{a.mission.description}</p>
      </div>
    </div>
  </section>

  <!-- WikiTV feature -->
  <section class="py-20 bg-slate-700 text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-slate-700 to-slate-900" aria-hidden="true"></div>
    <div class="relative max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow-light mb-5">{a.wikitv.eyebrow}</p>
          <h2 class="text-h1 mb-6">{a.wikitv.title}</h2>
          {a.wikitv.paragraphs.map((p: string) => (
            <p class="text-body text-slate-200 leading-relaxed mb-4">{p}</p>
          ))}
        </div>
        <div class="relative isolate aspect-square max-w-md mx-auto md:ml-auto">
          <div class="absolute -top-8 -left-8 w-64 h-64 bg-[#C1272D]/30 rounded-full blur-3xl z-0" aria-hidden="true"></div>
          <div class="absolute -bottom-8 -right-8 w-64 h-64 bg-orange-300/20 rounded-full blur-3xl z-0" aria-hidden="true"></div>
          <div class="relative z-10 h-full bg-white/5 backdrop-blur rounded-3xl shadow-2xl ring-1 ring-white/10 flex flex-col items-center justify-center p-8">
            <div class="w-24 h-24 rounded-full bg-[#C1272D]/20 flex items-center justify-center mb-6">
              <svg class="w-12 h-12 text-[#FCA5A5]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
              </svg>
            </div>
            <p class="text-h2 text-white mb-2">WikiTV</p>
            <p class="text-caption text-slate-300 uppercase tracking-wider text-center">Cambodia's first national education broadcast</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech / Built on real infrastructure -->
  <section class="py-20 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-14 max-w-2xl mx-auto">
        <h2 class="text-h1 text-[#C1272D] mb-4">{a.tech.title}</h2>
        <p class="text-lead text-gray-600">{a.tech.description}</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {a.tech.items.map((item: { title: string; description: string }, idx: number) => (
          <div class="card-lift bg-white border border-gray-200 shadow-md hover:shadow-xl rounded-xl p-7">
            <div class="w-12 h-12 rounded-full bg-[#C1272D]/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-[#C1272D]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={techIcons[idx]} />
              </svg>
            </div>
            <h3 class="text-h3 text-gray-900 mb-3">{item.title}</h3>
            <p class="text-body text-gray-700">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Value Proposition -->
  <section class="py-20 bg-gray-50 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-h1 text-[#C1272D] text-center mb-12">{a.values.title}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {a.values.items.map((item: string) => (
          <div class="card-lift bg-white border border-gray-200 rounded-xl shadow-md hover:shadow-xl p-8">
            <p class="text-lead text-gray-700">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Explore further (Solutions + Customers) -->
  <section class="py-20 bg-white border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-h1 text-[#C1272D] text-center mb-12">{a.explore.title}</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <a href={`/${lang}/solutions`} class="card-lift block bg-white border border-gray-200 shadow-md hover:shadow-xl rounded-xl p-8 group">
          <div class="w-12 h-12 rounded-full bg-[#C1272D]/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-[#C1272D]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
          </div>
          <h3 class="text-h3 text-gray-900 mb-3">{a.explore.solutions.title}</h3>
          <p class="text-body text-gray-600 mb-5">{a.explore.solutions.description}</p>
          <span class="inline-flex items-center text-[#C1272D] font-semibold group-hover:text-[#991B1F] transition-colors">
            {a.explore.solutions.cta}
            <svg class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>
        <a href={`/${lang}/customers`} class="card-lift block bg-white border border-gray-200 shadow-md hover:shadow-xl rounded-xl p-8 group">
          <div class="w-12 h-12 rounded-full bg-[#C1272D]/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-[#C1272D]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-h3 text-gray-900 mb-3">{a.explore.customers.title}</h3>
          <p class="text-body text-gray-600 mb-5">{a.explore.customers.description}</p>
          <span class="inline-flex items-center text-[#C1272D] font-semibold group-hover:text-[#991B1F] transition-colors">
            {a.explore.customers.cta}
            <svg class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Brand Partners -->
  <section class="py-20 bg-gray-50 border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-h1 text-[#C1272D] text-center mb-12">{a.brands.title}</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {
          (await import('../../data/brands.json')).brands.map((brand) => (
            <div class="flex flex-col items-center justify-center p-4">
              <img
                src={brand.logo}
                alt={brand.name}
                class="w-full max-w-[150px] h-auto object-contain mb-4"
              />
              <p class="text-center text-caption font-medium">{brand.name}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 text-center bg-red-50 border-t border-red-100">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-h1 text-[#C1272D] mb-4">{a.join_cta.title}</h2>
      <p class="text-lead text-gray-700 mb-8">{a.join_cta.description}</p>
      <a href={`/${lang}/contact`} class="btn btn-primary">
        {a.join_cta.button}
      </a>
    </div>
  </section>
</Base>
