---
import Base from '../../layouts/Base.astro';
import { getLangFromUrl, useTranslations, getContentTranslations } from '../../i18n/utils';
import { ui } from '../../i18n/ui';

export async function getStaticPaths() {
  return Object.keys(ui).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const content = await getContentTranslations(lang);

const about = content.about;

// Override default meta tags for this page
const meta = {
  title: 'About POSCAR Digital - Leading Digital Solutions Provider in Cambodia',
  description: 'Learn about POSCAR Digital, a leading provider of smart education, accounting, attendance, and ERP solutions in Cambodia. Discover our mission, vision, and innovative digital platforms including Wiki School and Vithean.',
  keywords: 'POSCAR Digital, company profile, about us, digital solutions, Cambodia, Wiki School, Vithean, ERP solutions, smart education, accounting software',
  ogImage: '/images/poscar-digital-about.jpg'
};
---

<Base meta={meta}>
  <!-- Hero Section -->
  <section class="py-20 px-6 md:px-12 lg:px-16 bg-slate-600 text-white">
    <div class="container mx-auto text-center">
      <h1 class="text-display mb-6">{about.hero.title}</h1>
      <p class="text-lead mb-8 max-w-2xl mx-auto">
        {about.hero.description}
      </p>
    </div>
  </section>

  <!-- Company Profile -->
  <section class="py-16 bg-white text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center max-w-4xl">
      <div class="p-10 bg-white shadow-lg rounded-lg transition-shadow duration-300 hover:shadow-xl">
        <h2 class="text-h1 mb-4">{about.profile.title}</h2>
        <p class="text-lead mb-0">
          {about.profile.description}
        </p>
      </div>
    </div>
  </section>

  <!-- Vision -->
  <section class="py-16 bg-gray-100 text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center">
      <h2 class="text-h1 mb-4">{about.vision.title}</h2>
      <p class="text-lead max-w-2xl mx-auto">
        {about.vision.description}
      </p>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-16 bg-white text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center">
      <h2 class="text-h1 mb-6">{about.mission.title}</h2>
      <p class="text-lead max-w-2xl mx-auto">
        {about.mission.description}
      </p>
    </div>
  </section>

  <!-- Value Proposition -->
  <section class="py-16 bg-gray-50 text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center">
      <h2 class="text-h1 mb-10">{about.values.title}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {about.values.items.map((item: string) => (
          <div class="card-lift p-8 bg-white rounded-lg shadow-md hover:shadow-xl">
            <p class="text-lead mb-0">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Solutions -->
  <section class="py-16 bg-white text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center">
      <h2 class="text-h1 mb-6">{about.solutions.title}</h2>
      <p class="text-lead mb-8 max-w-2xl mx-auto">
        {t('products_services.hero.description')}
      </p>
      <a href={`/${lang}/solutions`} class="btn btn-ghost">
        {about.solutions.cta} →
      </a>
    </div>
  </section>

  <!-- Our Customers -->
  <section class="py-16 bg-gray-100 text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center">
      <h2 class="text-h1 mb-6">{about.customers.title}</h2>
      <p class="text-lead mb-8 max-w-2xl mx-auto">
        {about.customers.description}
      </p>
      <a href={`/${lang}/customers`} class="btn btn-ghost">
        {about.customers.cta} →
      </a>
    </div>
  </section>

  <!-- Our Team -->
  <section class="py-16 bg-white text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto max-w-4xl">
      <div class="mb-8">
        <img src="/images/history.jpg" alt={about.team.title} class="w-full rounded-lg shadow-lg" />
      </div>
      <h2 class="text-h1 mb-4">{about.team.title}</h2>
      <p class="text-body text-gray-700 leading-relaxed">
        {about.team.description}
      </p>
    </div>
  </section>

  <!-- Achievements -->
  <section class="py-16 bg-gray-100 text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto max-w-4xl">
      <h2 class="text-h1 text-center mb-12">{about.achievements.title}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {about.achievements.items.map((item: { value: string; label: string }) => (
          <div class="text-center">
            <div class="text-stat text-slate-600 mb-2">{item.value}</div>
            <p class="text-lead">{item.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Brand Partners -->
  <section class="py-16 bg-white text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto max-w-4xl">
      <h2 class="text-h1 text-center mb-12">{about.brands.title}</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {
          (await import('../../data/brands.json')).brands.map((brand) => (
            <div class="flex flex-col items-center justify-center p-4">
              <img
                src={brand.logo}
                alt={brand.name}
                class="w-full max-w-[150px] h-auto object-contain mb-4"
              />
              <p class="text-center text-caption font-medium">{brand.name}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 text-center px-6 md:px-12 lg:px-16 bg-red-50 border-t border-red-100">
    <div class="container mx-auto max-w-2xl">
      <h2 class="text-h1 text-[#C1272D] mb-4">{about.join_cta.title}</h2>
      <p class="text-lead text-gray-700 mb-8">{about.join_cta.description}</p>
      <a href={`/${lang}/contact`} class="btn btn-primary">
        {about.join_cta.button}
      </a>
    </div>
  </section>
</Base>
