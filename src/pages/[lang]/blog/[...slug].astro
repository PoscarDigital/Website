---
import Base from '../../../layouts/Base.astro';
import { useTranslations } from '../../../i18n/utils';
import { getCollection, type CollectionEntry } from 'astro:content';
import { ui } from '../../../i18n/ui';

type Languages = keyof typeof ui;

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return Object.keys(ui).flatMap((lang) => {
    return blogEntries.map((entry) => ({
      params: { lang, slug: entry.slug },
      props: { entry },
    }));
  });
}

const { lang } = Astro.params as { lang: Languages };
const { entry } = Astro.props as { entry: CollectionEntry<'blog'> };
const { Content } = await entry.render();
const t = useTranslations(lang);

const formattedDate = entry.data.date.toLocaleDateString(lang === 'km' ? 'km-KH' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const isPress = entry.data.category === 'Press' && entry.data.source_url;

// Pull a YouTube video id out of any of the common URL shapes.
function getYouTubeId(url: string | undefined): string | null {
  if (!url) return null;
  const patterns = [
    /(?:youtube\.com|youtube-nocookie\.com)\/watch\?(?:[^&]*&)*v=([\w-]+)/i,
    /(?:youtube\.com|youtube-nocookie\.com)\/embed\/([\w-]+)/i,
    /(?:youtube\.com|youtube-nocookie\.com)\/shorts\/([\w-]+)/i,
    /youtu\.be\/([\w-]+)/i,
  ];
  for (const p of patterns) {
    const m = url.match(p);
    if (m) return m[1];
  }
  return null;
}
const sourceVideoId = getYouTubeId(entry.data.source_url);
const isYouTubeSource = !!sourceVideoId;

// Detect whether the thumbnail is a brand mark (logo) vs an editorial photo.
// Brand logos sit in a white card with padding; photos go full-bleed at 16:9.
const isLogoThumb = !!entry.data.thumbnail && entry.data.thumbnail.includes('/brand/');

// Reading time. Khmer has no inter-word spaces, so count characters at
// roughly 700 chars/minute. Fall back to a 220-word-per-minute estimate
// for predominantly Latin-script bodies.
const body = entry.body || '';
const khmerChars = (body.match(/[ក-៿]/g) || []).length;
const words = body.replace(/[ក-៿]/g, '').split(/\s+/).filter(Boolean).length;
const minutes = Math.max(1, Math.round(khmerChars / 700 + words / 220));

// Related posts: same category, most recent, excluding self. If fewer than 3
// match, fill from any category.
const allPosts = await getCollection('blog');
const otherPosts = allPosts.filter((e: CollectionEntry<'blog'>) => e.slug !== entry.slug);
const sameCat = otherPosts.filter((e: CollectionEntry<'blog'>) => e.data.category === entry.data.category);
const related = [
  ...sameCat,
  ...otherPosts.filter((e: CollectionEntry<'blog'>) => !sameCat.includes(e)),
]
  .sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3)
  .map((post: CollectionEntry<'blog'>) => ({
    post,
    isLogo: !!post.data.thumbnail && post.data.thumbnail.includes('/brand/'),
  }));
---

<Base>
  <article class="bg-white">
    <!-- Top breadcrumb bar — minimal, no competing labels -->
    <nav aria-label="Article navigation" class="border-b border-gray-100 bg-white">
      <div class="max-w-4xl mx-auto px-4 py-4">
        <a href={`/${lang}/blogs/1`} class="inline-flex items-center text-caption text-gray-600 hover:text-[#C1272D] transition-colors font-medium">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          {t('common.buttons.view_all')}
        </a>
      </div>
    </nav>

    <!-- Headline section — title is the hero; everything else is secondary -->
    <header class="max-w-4xl mx-auto px-4 pt-14 pb-10">
      <!-- Kicker (tiny, uppercase, brand red) -->
      {entry.data.category && (
        <p class="text-micro font-bold uppercase tracking-[0.18em] text-[#C1272D] mb-6">
          {entry.data.category}
        </p>
      )}
      <!-- The title — fixed 1.8rem with line-height 2 for Khmer legibility -->
      <h1 class="font-extrabold text-gray-900 text-[1.8rem] leading-[2] tracking-tight mb-8">
        {entry.data.title}
      </h1>
      <!-- Lede subtitle — clearly subordinate (lead size, lighter color, no bold) -->
      {entry.data.description && (
        <p class="text-lead font-normal text-gray-500 leading-relaxed max-w-3xl mb-10">
          {entry.data.description}
        </p>
      )}
      <!-- Byline — small, uppercase, tracked. Reads as caption metadata. -->
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 pt-6 border-t border-gray-200 text-micro uppercase tracking-wider text-gray-500">
        {entry.data.source_name && (
          <>
            <span class="font-bold text-gray-700">{entry.data.source_name}</span>
            <span aria-hidden="true" class="text-gray-300">·</span>
          </>
        )}
        <span>{formattedDate}</span>
        <span aria-hidden="true" class="text-gray-300">·</span>
        <span>{minutes} min read</span>
      </div>
    </header>

    <!-- Hero: brand-logo style (white card, padded) -->
    {entry.data.thumbnail && isLogoThumb && (
      <div class="max-w-4xl mx-auto px-4 mb-16">
        <div class="bg-gray-50 rounded-2xl border border-gray-200 flex items-center justify-center p-12">
          <img
            src={entry.data.thumbnail}
            alt={entry.data.title}
            class="max-h-40 w-auto object-contain"
            loading="eager"
          />
        </div>
      </div>
    )}

    <!-- Hero: editorial photo. Natural aspect ratio (no forced 16:10
         crop) so press photos and screenshots keep all their context.
         Capped at 80vh so portrait images don't dominate the page.
         Band, dot-texture, red glow, and ring all kept for the
         editorial framing. -->
    {entry.data.thumbnail && !isLogoThumb && (
      <section class="relative bg-gradient-to-b from-red-50 via-red-50/60 to-white py-12 md:py-16 mb-16">
        <div class="absolute inset-0 bg-[url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2240%22 height=%2240%22><circle cx=%221%22 cy=%221%22 r=%221%22 fill=%22%23C1272D%22 opacity=%220.08%22/></svg>')] opacity-50" aria-hidden="true"></div>
        <figure class="relative max-w-6xl mx-auto px-4 flex justify-center">
          <img
            src={entry.data.thumbnail}
            alt={entry.data.title}
            class="max-w-full h-auto max-h-[80vh] w-auto rounded-2xl shadow-[0_25px_70px_-15px_rgba(193,39,45,0.35)] ring-1 ring-red-100 bg-white"
            loading="eager"
          />
        </figure>
      </section>
    )}

    <!-- Article body -->
    <div class="max-w-3xl mx-auto px-4 pb-8">
      {isYouTubeSource && (
        <figure class="mb-10">
          <div class="relative aspect-video rounded-2xl overflow-hidden shadow-lg ring-1 ring-gray-200 bg-black">
            <iframe
              src={`https://www.youtube-nocookie.com/embed/${sourceVideoId}`}
              title={entry.data.title}
              class="absolute inset-0 w-full h-full"
              loading="lazy"
              allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
            ></iframe>
          </div>
        </figure>
      )}

      <div id="blog-article-body" class="prose prose-slate prose-lg max-w-none
                  prose-headings:font-bold prose-headings:text-gray-900
                  prose-p:leading-relaxed
                  prose-a:text-[#C1272D] prose-a:no-underline hover:prose-a:underline
                  prose-strong:text-gray-900
                  prose-blockquote:border-l-4 prose-blockquote:border-[#C1272D]
                  prose-blockquote:not-italic prose-blockquote:text-gray-700
                  prose-img:rounded-xl">
        <Content />
      </div>

      {isPress && (
        <p class="mt-10 pt-6 border-t border-gray-200 text-caption text-gray-500 italic">
          Originally published in
          {' '}
          <a href={entry.data.source_url} target="_blank" rel="noopener noreferrer" class="text-[#C1272D] hover:text-[#991B1F] font-semibold not-italic underline-offset-2 hover:underline">
            {entry.data.source_name}
          </a>.
        </p>
      )}

      {entry.data.tags && entry.data.tags.length > 0 && (
        <div class="mt-10 flex flex-wrap items-center gap-2">
          <span class="text-caption text-gray-500 uppercase tracking-wider mr-2">Tags</span>
          {entry.data.tags.map((tag: string) => (
            <span class="bg-gray-100 hover:bg-red-50 text-gray-700 hover:text-[#C1272D] px-3 py-1 rounded-full text-caption font-medium transition-colors">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </div>

    <!-- Source CTA card -->
    {isPress && (
      <aside class="max-w-3xl mx-auto px-4 mt-8">
        <div class="bg-red-50 border border-red-100 rounded-2xl p-8 md:p-10">
          <p class="text-caption uppercase tracking-wider text-gray-500 mb-2">
            {isYouTubeSource ? 'Watch the original video' : 'Read the original article'}
          </p>
          <p class="text-h3 text-gray-900 mb-6">{entry.data.source_name}</p>
          <a href={entry.data.source_url} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            {isYouTubeSource ? 'Watch on YouTube' : `Read on ${entry.data.source_name}`}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
      </aside>
    )}

    <!-- Inline transform: any YouTube anchor inside the article body becomes
         a responsive embed in-place. Runs once on DOMContentLoaded. -->
    <script is:inline>
      (() => {
        const root = document.getElementById('blog-article-body');
        if (!root) return;
        const getId = (url) => {
          const patterns = [
            /(?:youtube\.com|youtube-nocookie\.com)\/watch\?(?:[^&]*&)*v=([\w-]+)/i,
            /(?:youtube\.com|youtube-nocookie\.com)\/embed\/([\w-]+)/i,
            /(?:youtube\.com|youtube-nocookie\.com)\/shorts\/([\w-]+)/i,
            /youtu\.be\/([\w-]+)/i,
          ];
          for (const p of patterns) {
            const m = url.match(p);
            if (m) return m[1];
          }
          return null;
        };
        root.querySelectorAll('a[href]').forEach((a) => {
          const id = getId(a.getAttribute('href') || '');
          if (!id) return;
          const wrap = document.createElement('figure');
          wrap.className = 'my-6 relative aspect-video rounded-2xl overflow-hidden shadow-lg ring-1 ring-gray-200 bg-black';
          const iframe = document.createElement('iframe');
          iframe.src = 'https://www.youtube-nocookie.com/embed/' + id;
          iframe.title = a.textContent && a.textContent.trim() ? a.textContent.trim() : 'YouTube video';
          iframe.className = 'absolute inset-0 w-full h-full';
          iframe.loading = 'lazy';
          iframe.referrerPolicy = 'strict-origin-when-cross-origin';
          iframe.allow = 'accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
          iframe.allowFullscreen = true;
          wrap.appendChild(iframe);
          // Replace the anchor's parent paragraph if the anchor is the only thing in it,
          // otherwise replace just the anchor. Keeps surrounding text intact.
          const p = a.parentElement;
          if (p && p.tagName === 'P' && p.textContent && p.textContent.trim() === (a.textContent || '').trim()) {
            p.replaceWith(wrap);
          } else {
            a.replaceWith(wrap);
          }
        });
      })();
    </script>

    <!-- Related posts -->
    {related.length > 0 && (
      <section class="bg-gray-50 border-t border-gray-100 mt-20 py-16">
        <div class="max-w-6xl mx-auto px-4">
          <h2 class="text-h2 text-[#C1272D] mb-10 text-center">
            More {entry.data.category === 'Press' ? 'press coverage' : 'articles'}
          </h2>
          <div class="grid md:grid-cols-3 gap-6">
            {related.map(({ post, isLogo }) => (
              <a href={`/${lang}/blog/${post.slug}`} class="card-lift block bg-white rounded-xl shadow-md hover:shadow-xl overflow-hidden border border-gray-200 group">
                {post.data.thumbnail && (
                  <div class={isLogo ? 'relative bg-gray-50 flex items-center justify-center h-44 p-6' : 'relative h-44 overflow-hidden'}>
                    <img
                      src={post.data.thumbnail}
                      alt={post.data.title}
                      class={isLogo ? 'max-h-full max-w-full object-contain' : 'absolute inset-0 w-full h-full object-cover'}
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="p-5">
                  <div class="flex items-center gap-2 text-caption text-gray-500 mb-2">
                    <span>{post.data.date.toLocaleDateString()}</span>
                    {post.data.source_name && (
                      <>
                        <span aria-hidden="true">·</span>
                        <span>{post.data.source_name}</span>
                      </>
                    )}
                  </div>
                  <h3 class="text-h4 text-gray-900 line-clamp-3 group-hover:text-[#C1272D] transition-colors">
                    {post.data.title}
                  </h3>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</Base>
