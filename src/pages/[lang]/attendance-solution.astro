---
import Base from "../../layouts/Base.astro";
import {
  getLangFromUrl,
  useTranslations,
  getContentTranslations,
} from "../../i18n/utils";
import { ui } from "../../i18n/ui";

export async function getStaticPaths() {
  return Object.keys(ui).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const content = await getContentTranslations(lang);

// Get translations
const title = content.attendance.title;
const subtitle = content.attendance.subtitle;
const operationsTitle = content.attendance.operations.title;
const operationsItems = content.attendance.operations.items;
const learningTitle = content.attendance.learning.title;
const learningItems = content.attendance.learning.items;
const benefitsTitle = content.attendance.benefits.title;
const benefits = content.attendance.benefits.items;
const ctaTitle = content.attendance.cta.title;
const ctaButton = content.attendance.cta.button;
---

<Base>
  <!-- Hero Section -->
  <section class="bg-slate-600 text-white py-20 text-center">
    <h1 class="text-display mb-4">{title}</h1>
    <p class="text-lead">{subtitle}</p>
  </section>

  <!-- Overview Features -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 grid md:grid-cols-2 gap-10 text-center">
      <div>
        <h2 class="text-h2 mb-4">{operationsTitle}</h2>
        <ul class="space-y-2 text-caption text-gray-700 inline-block text-left">
          {
            Array.isArray(operationsItems) &&
              operationsItems.map((item: string) => <li>• {item}</li>)
          }
        </ul>
      </div>
      <div>
        <h2 class="text-h2 mb-4">{learningTitle}</h2>
        <ul class="space-y-2 text-caption text-gray-700 inline-block text-left">
          {
            Array.isArray(learningItems) &&
              learningItems.map((item: string) => <li>• {item}</li>)
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- Promotion Banner -->
  <section class="py-10 text-[#C1272D] text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-h1 mb-4">Smart Attendance Management</h2>
      <p class="text-lead mb-6">
        Our attendance solution combines advanced hardware with intelligent
        software to provide accurate and efficient attendance tracking.
      </p>
      <img
        src="/images/attendance system/attendance.png"
        alt="Attendance System Preview"
        class="mx-auto rounded-lg shadow-xl max-w-full h-auto"
      />
    </div>
  </section>

  <!-- Key Benefits -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h2 class="text-h1 text-[#C1272D] mb-12">{benefitsTitle}</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {
          Array.isArray(benefits) &&
            benefits.map((benefit: { title: string; description: string }) => (
              <div>
                <h3 class="text-h3 mb-2">{benefit.title}</h3>
                <p class="text-caption text-gray-600">{benefit.description}</p>
              </div>
            ))
        }
      </div>
      <div class="mt-12">
        <a
          href="https://attendance.poscardigital.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-[#C1272D] text-white px-6 py-3 rounded-full hover:bg-[#991B1F] transition-colors duration-300"
        >
          Explore Attendance Solution
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 text-center bg-white">
    <h2 class="text-h1 mb-4">{ctaTitle}</h2>
    <a
      href={`/${lang}/contact`}
      class="mt-4 inline-block bg-[#C1272D] text-white px-6 py-3 rounded-full hover:bg-[#991B1F] transition-colors duration-300"
    >
      {ctaButton}
    </a>
  </section>
</Base>
