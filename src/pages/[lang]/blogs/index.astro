---
import { ui } from '../../../i18n/ui';

type Languages = keyof typeof ui;

export function getStaticPaths() {
  return Object.keys(ui).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Languages };
---
<meta http-equiv="refresh" content={`0;url=/${lang}/blogs/1`} />
