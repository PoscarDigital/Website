---
import Base from '../../../layouts/Base.astro';
import { getLangFromUrl, useTranslations, getContentTranslations } from '../../../i18n/utils';
import type { GetStaticPaths } from 'astro';
import { ui } from '../../../i18n/ui';
import { getCollection, type CollectionEntry } from 'astro:content';

type Languages = keyof typeof ui;

interface PageData {
  data: CollectionEntry<'blog'>[];
  currentPage: number;
  lastPage: number;
  url: {
    prev: string | null;
    next: string | null;
  };
}

export const getStaticPaths: GetStaticPaths = async () => {
  const blogEntries = await getCollection('blog');
  const sortedEntries = blogEntries.sort(
    (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
      b.data.date.valueOf() - a.data.date.valueOf(),
  );

  const pageSize = 9;
  const totalPages = Math.max(1, Math.ceil(sortedEntries.length / pageSize));

  const paths = [];
  for (const lang of Object.keys(ui) as Languages[]) {
    for (let page = 1; page <= totalPages; page++) {
      const start = (page - 1) * pageSize;
      const end = start + pageSize;
      const pageEntries = sortedEntries.slice(start, end);

      paths.push({
        params: { lang, page: String(page) },
        props: {
          page: {
            data: pageEntries,
            currentPage: page,
            lastPage: totalPages,
            url: {
              prev: page > 1 ? `/${lang}/blogs/${page - 1}` : null,
              next: page < totalPages ? `/${lang}/blogs/${page + 1}` : null,
            },
          },
        },
      });
    }
  }

  return paths;
};

const { page } = Astro.props as { page: PageData };
const { lang } = Astro.params as { lang: Languages };
const t = useTranslations(lang);
const content = await getContentTranslations(lang);

// Search index is no longer inlined — it's a separate JSON file generated
// by scripts/build-blog-index.mjs into public/blog-index.json (via the
// `prebuild` npm script). The browser fetches it lazily on first search
// interaction, then caches it. Saves ~15 KB on every blog listing page.

// Anything in this object must be JSON-serializable: define:vars uses
// JSON, which silently drops functions. The result-count formatter is
// defined in the client script body below, not here.
const searchUi = {
  placeholder: lang === 'km' ? 'ស្វែងរកអត្ថបទ…' : 'Search articles…',
  clear: lang === 'km' ? 'សម្អាត' : 'Clear',
  searching: lang === 'km' ? 'កំពុងស្វែងរក…' : 'Searching…',
  failed: lang === 'km' ? 'មិនអាចស្វែងរកបាន' : 'Search unavailable',
  empty: lang === 'km' ? 'រកមិនឃើញអ្វីសម្រាប់' : 'No results for',
  readMore: await t('common.buttons.read_more'),
};
---

<Base>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-b from-red-50 to-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <p class="eyebrow mb-5">News &amp; Press</p>
      <h1 class="text-display text-[#C1272D] mb-4">{content.home.blogs.title}</h1>
      <p class="text-lead text-gray-700 max-w-2xl mx-auto">{content.home.blogs.subtitle}</p>
    </div>
  </section>

  <!-- Search -->
  <section class="bg-white pt-10">
    <div class="max-w-2xl mx-auto px-4">
      <label for="blog-search" class="sr-only">{searchUi.placeholder}</label>
      <div class="relative">
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          id="blog-search"
          type="search"
          placeholder={searchUi.placeholder}
          autocomplete="off"
          class="w-full pl-12 pr-12 py-3 rounded-full border border-gray-300 bg-white text-body placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#C1272D] focus:border-[#C1272D] transition"
        />
        <button
          id="blog-search-clear"
          type="button"
          aria-label={searchUi.clear}
          class="hidden absolute right-3 top-1/2 -translate-y-1/2 w-8 h-8 flex items-center justify-center rounded-full text-gray-400 hover:text-gray-700 hover:bg-gray-100 transition"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <p id="blog-search-count" class="text-caption text-gray-500 mt-3 text-center hidden" aria-live="polite"></p>
    </div>
  </section>

  <!-- Blog Posts Grid -->
  <section class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <!-- Default paginated grid (visible when no search) -->
      <div id="blog-paginated" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {page.data.map((post: CollectionEntry<'blog'>) => (
          <a
            href={`/${lang}/blog/${post.slug}`}
            class="card-lift block bg-white rounded-xl shadow-md hover:shadow-xl overflow-hidden border border-gray-200 group"
          >
            {post.data.thumbnail && (
              <div class="relative bg-gray-50 flex items-center justify-center h-48 p-6">
                <img
                  src={post.data.thumbnail}
                  alt={post.data.title}
                  class="max-h-full max-w-full object-contain"
                  loading="lazy"
                />
                {post.data.category && (
                  <span class="absolute top-3 left-3 inline-block bg-[#C1272D] text-white text-micro font-semibold uppercase tracking-wider px-3 py-1 rounded-full">
                    {post.data.category}
                  </span>
                )}
              </div>
            )}
            <div class="p-6">
              <div class="flex flex-wrap items-center text-caption text-gray-500 mb-3 gap-x-2">
                <span>{post.data.date.toLocaleDateString()}</span>
                {post.data.source_name && (
                  <>
                    <span>·</span>
                    <span>{post.data.source_name}</span>
                  </>
                )}
              </div>
              <h3 class="text-h3 mb-3 text-gray-900 line-clamp-3">{post.data.title}</h3>
              {post.data.description && (
                <p class="text-body text-gray-600 mb-4 line-clamp-2">{post.data.description}</p>
              )}
              <span class="inline-flex items-center text-[#C1272D] font-semibold group-hover:text-[#991B1F] transition-colors">
                {t('common.buttons.read_more')}
                <svg class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      <!-- Search results grid (filled by JS, hidden when no search) -->
      <div id="blog-search-results" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"></div>
      <p id="blog-search-empty" class="hidden text-center text-lead text-gray-500 py-16"></p>

      <!-- Pagination (visible only when no search) -->
      {page.lastPage > 1 && (
        <div id="blog-pagination" class="mt-14 flex items-center justify-center gap-3">
          {page.url.prev ? (
            <a href={page.url.prev} class="btn btn-secondary">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
              {t('common.buttons.previous')}
            </a>
          ) : (
            <span class="btn btn-secondary opacity-40 pointer-events-none">
              {t('common.buttons.previous')}
            </span>
          )}
          <span class="px-4 text-caption text-gray-600">
            {t('common.pagination.page')} {page.currentPage} {t('common.pagination.of')} {page.lastPage}
          </span>
          {page.url.next ? (
            <a href={page.url.next} class="btn btn-secondary">
              {t('common.buttons.next')}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ) : (
            <span class="btn btn-secondary opacity-40 pointer-events-none">
              {t('common.buttons.next')}
            </span>
          )}
        </div>
      )}
    </div>
  </section>

  <script define:vars={{ lang, searchUi }}>
    (() => {
      const input = document.getElementById('blog-search');
      const clearBtn = document.getElementById('blog-search-clear');
      const countEl = document.getElementById('blog-search-count');
      const paginated = document.getElementById('blog-paginated');
      const pagination = document.getElementById('blog-pagination');
      const results = document.getElementById('blog-search-results');
      const empty = document.getElementById('blog-search-empty');
      if (!input || !paginated || !results || !empty || !countEl || !clearBtn) return;

      // Result-count formatter. Defined here (not in searchUi) because
      // define:vars JSON-serializes its inputs and silently drops
      // functions.
      const formatCount = (n) =>
        lang === 'km'
          ? `លទ្ធផល ${n}`
          : `${n} ${n === 1 ? 'result' : 'results'}`;

      const escapeHtml = (s) =>
        String(s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');

      // Lazy fetch + cache the index. First search interaction triggers
      // the fetch; subsequent searches are instant.
      let indexCache = null;
      let indexPromise = null;
      const loadIndex = () => {
        if (indexCache) return Promise.resolve(indexCache);
        if (indexPromise) return indexPromise;
        indexPromise = fetch('/blog-index.json')
          .then((r) => {
            if (!r.ok) throw new Error('Failed to load search index');
            return r.json();
          })
          .then((data) => {
            indexCache = data.map((p) => ({
              ...p,
              dateFormatted: p.date ? new Date(p.date).toLocaleDateString() : '',
              haystack: [p.title, p.description, p.source, p.category, (p.tags || []).join(' ')]
                .join(' ')
                .toLowerCase(),
            }));
            return indexCache;
          })
          .catch((e) => {
            indexPromise = null;
            throw e;
          });
        return indexPromise;
      };

      // Warm the cache on idle so the first search feels instant. Falls back
      // to setTimeout where requestIdleCallback isn't available (Safari).
      const warm = () => { loadIndex().catch(() => {}); };
      if ('requestIdleCallback' in window) {
        window.requestIdleCallback(warm, { timeout: 2000 });
      } else {
        setTimeout(warm, 500);
      }

      const renderCard = (p) => {
        const dateStr = p.dateFormatted || p.date || '';
        const dateLine = p.source ? `${escapeHtml(dateStr)} · ${escapeHtml(p.source)}` : escapeHtml(dateStr);
        const categoryPill = p.category
          ? `<span class="absolute top-3 left-3 inline-block bg-[#C1272D] text-white text-micro font-semibold uppercase tracking-wider px-3 py-1 rounded-full">${escapeHtml(p.category)}</span>`
          : '';
        const thumb = p.thumbnail
          ? `<div class="relative bg-gray-50 flex items-center justify-center h-48 p-6"><img src="${escapeHtml(p.thumbnail)}" alt="${escapeHtml(p.title)}" class="max-h-full max-w-full object-contain" loading="lazy" />${categoryPill}</div>`
          : '';
        const desc = p.description
          ? `<p class="text-body text-gray-600 mb-4 line-clamp-2">${escapeHtml(p.description)}</p>`
          : '';
        return `
          <a href="/${lang}/blog/${escapeHtml(p.slug)}/" class="card-lift block bg-white rounded-xl shadow-md hover:shadow-xl overflow-hidden border border-gray-200 group">
            ${thumb}
            <div class="p-6">
              <div class="flex flex-wrap items-center text-caption text-gray-500 mb-3 gap-x-2">${dateLine}</div>
              <h3 class="text-h3 mb-3 text-gray-900 line-clamp-3">${escapeHtml(p.title)}</h3>
              ${desc}
              <span class="inline-flex items-center text-[#C1272D] font-semibold group-hover:text-[#991B1F] transition-colors">
                ${escapeHtml(searchUi.readMore)}
                <svg class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>`;
      };

      const setSearching = (on) => {
        paginated.classList.toggle('hidden', on);
        if (pagination) pagination.classList.toggle('hidden', on);
        results.classList.toggle('hidden', !on);
        countEl.classList.toggle('hidden', !on);
        clearBtn.classList.toggle('hidden', !on);
      };

      const update = async () => {
        const q = input.value.trim().toLowerCase();
        if (!q) {
          setSearching(false);
          results.innerHTML = '';
          empty.classList.add('hidden');
          return;
        }
        setSearching(true);
        // Show "Searching…" while the index loads on first interaction;
        // for cached subsequent searches this flashes too briefly to see.
        if (!indexCache) countEl.textContent = searchUi.searching;
        try {
          const data = await loadIndex();
          // Bail if the user already typed something else while we were
          // loading — only render results for the current query.
          if (q !== input.value.trim().toLowerCase()) return;
          const matches = data.filter((p) => p.haystack.includes(q));
          countEl.textContent = formatCount(matches.length);
          if (matches.length === 0) {
            results.classList.add('hidden');
            empty.classList.remove('hidden');
            empty.textContent = `${searchUi.empty} "${input.value.trim()}"`;
          } else {
            empty.classList.add('hidden');
            results.classList.remove('hidden');
            results.innerHTML = matches.map(renderCard).join('');
          }
        } catch (_e) {
          countEl.textContent = searchUi.failed;
        }
      };

      input.addEventListener('input', update);
      input.addEventListener('search', update);
      clearBtn.addEventListener('click', () => {
        input.value = '';
        update();
        input.focus();
      });
      // Initialize from URL ?q= so search results can be linked
      const urlQ = new URLSearchParams(window.location.search).get('q');
      if (urlQ) {
        input.value = urlQ;
        update();
      }
    })();
  </script>
</Base>
