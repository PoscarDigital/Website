---
// src/pages/[lang]/index.astro
import Base from "../../layouts/Base.astro";
import { getLangFromUrl, useTranslations, getContentTranslations } from '../../i18n/utils';
import { ui, defaultLang } from '../../i18n/ui';

export async function getStaticPaths() {
  return Object.keys(ui).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const content = await getContentTranslations(lang);
---

<Base>
  <!-- Welcome Section -->
  <section class="bg-slate-600 text-white py-16">
    <div class="container mx-auto text-center">
      <h1 class="text-5xl font-extrabold mb-4">{content.home.hero.title}</h1>
      <p class="text-xl mb-8">{content.home.hero.subtitle}</p>
      <p class="text-xl mb-8">{content.home.hero.description}</p>
      <a
      href={`/${lang}/product-services/`} 
        class="bg-transparent border-2 border-white text-white py-3 px-6 rounded-lg text-lg font-semibold hover:bg-white hover:text-slate-600 transition-colors duration-300"
      >
        {content.common.buttons.get_started}
      </a>
    </div>
  </section>

  <section class="py-16 bg-white text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto grid grid-cols-1 md:grid-cols-2 gap-12">
      
      <!-- Text Section: About Us Content (on the left) -->
      <div class="text-center md:text-left">
        <h2 class="text-3xl md:text-4xl font-semibold mb-6">{content.home.about.title}</h2>
        <p class="text-lg md:text-xl mb-8">
          {content.home.about.description}
        </p>
        <div class="text-center md:text-left">
          <h2 class="text-1xl md:text-2xl font-semibold mb-6">{content.home.about.vision.title}</h2>
          <p class="text-lg md:text-xl mb-8">
            {content.home.about.vision.content}
          </p>
        </div>
      </div>
  
      <!-- Video Section: Embedded YouTube Video (on the right) -->
      <div class="flex justify-center items-center shadow-xl">
        <div class="w-full max-w-3xl">
          <!-- Adjusted iframe for a larger video -->
          <iframe
            class="w-full h-[400px] md:h-[300px]"
            src="https://www.youtube.com/embed/SUGhEr_7B3c"
            title="Our Vision Video"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen>
          </iframe>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Featured Products & Services Section -->
  <section class="py-16 bg-gray-100 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-semibold mb-6">
        {content.home.products.title}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Example of Product/Service Card -->
        <div class="bg-white shadow-xl rounded-lg p-6">
          <h3 class="text-2xl font-semibold mb-4">{content.home.products.items.k12.title}</h3>
          <p class="text-lg mb-4">
            {content.home.products.items.k12.description}
          </p>
          <a
            href={`/${lang}/product-services`}
            class="text-red-600 font-semibold hover:underline transition-colors duration-300"
          >
            {content.common.buttons.learn_more}
          </a>
        </div>
        <div class="bg-white shadow-xl rounded-lg p-6">
          <h3 class="text-2xl font-semibold mb-4">{content.home.products.items.university.title}</h3>
          <p class="text-lg mb-4">
            {content.home.products.items.university.description}
          </p>
          <a
            href={`/${lang}/product-services`}
            class="text-red-600 font-semibold hover:underline transition-colors duration-300"
          >
            {content.common.buttons.learn_more}
          </a>
        </div>
        <div class="bg-white shadow-xl rounded-lg p-6">
          <h3 class="text-2xl font-semibold mb-4">{content.home.products.items.hrm.title}</h3>
          <p class="text-lg mb-4">
            {content.home.products.items.hrm.description}
          </p>
          <a
            href={`/${lang}/product-services`}
            class="text-red-600 font-semibold hover:underline transition-colors duration-300"
          >
            {content.common.buttons.learn_more}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action Section -->
  <section class="py-16 text-black text-center px-6 md:px-12 lg:px-16">
    <div class="container mx-auto">
      <h2 class="text-3xl md:text-4xl font-semibold mb-4">
        {content.home.contact.title}
      </h2>
      <p class="text-lg md:text-xl mb-6">
        {content.home.contact.description}
      </p>
      <a
      href={`/${lang}/contact/`} 
        class="border-2 border-slate-600  text-slate-600 py-3 px-8 rounded-lg text-lg font-semibold hover:bg-slate-600 hover:text-white transition-colors duration-300"
      >
        {content.common.buttons.contact_us}
      </a>
    </div>
  </section>
</Base> 