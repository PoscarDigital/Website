---
// src/pages/[lang]/index.astro
import Base from '../../layouts/Base.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { ui } from '../../i18n/ui';

export async function getStaticPaths() {
  return Object.keys(ui).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Sample blog data - replace with actual content from your CMS or data source
const blogItems = [
  {
    date: "May 2025",
    author: "Admin",
    title: "POSCAR Supports MoEYS with AI-Ready Solutions",
    description: "How we're building next-gen education systems for Cambodia's Ministry of Education.",
    link: `/${lang}/blogs/ai-solutions`
  },
  {
    date: "April 2025",
    author: "Tech Team",
    title: "Behind the Scenes of Vithean",
    description: "A look into how our cloud accounting platform reshapes SME operations.",
    link: `/${lang}/blogs/vithean-behind-scenes`
  },
  {
    date: "March 2025",
    author: "UX Lead",
    title: "Why Digital Document Flow Matters",
    description: "Discover how BluePinn DocFlow improves traceability in approvals.",
    link: `/${lang}/blogs/digital-document-flow`
  }
];
---

<Base>
  <!-- Hero Section -->
  <section id="home" class="bg-red-50 py-20 text-center text-[#C1272D]">
    <div class="container mx-auto">
      <h2 class="text-4xl font-bold mb-4">{t('home.hero.title')}</h2>
      <p class="text-lg text-gray-700 mb-6 max-w-xl mx-auto">
        {t('home.hero.description')}
      </p>
      <a 
        href={`/${lang}/contact/`}
        class="px-6 py-3 bg-[#C1272D] text-white rounded-full hover:bg-[#991B1F] transition-colors duration-300"
      >
        {t('common.buttons.get_started')}
      </a>
    </div>
  </section>

  <!-- Solutions Section -->
  <section id="solutions" class="py-16 max-w-7xl mx-auto px-4">
    <div class="text-center mb-12">
      <h3 class="text-3xl font-bold mb-4 text-[#C1272D]">{t('products_services.hero.title')}</h3>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-8">
        {t('products_services.hero.description')}
      </p>
      <a 
        href={`/${lang}/solutions`}
        class="inline-block text-[#C1272D] font-semibold hover:text-[#991B1F] transition-colors duration-300"
      >
        {t('common.buttons.explore_more')} →
      </a>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Education Solutions -->
      <div class="bg-white shadow-lg rounded-xl overflow-hidden hover:shadow-xl transition-shadow duration-300">
        <div class="aspect-w-16 aspect-h-9">
          <img 
            src="/images/education-solutions.jpg" 
            alt="Education Solutions" 
            class="w-full h-48 object-cover"
          />
        </div>
        <div class="p-6">
          <h4 class="text-xl font-semibold mb-3 text-[#C1272D]">{t('products_services.education.title')}</h4>
          <ul class="space-y-2 text-gray-600 mb-4">
            <li class="flex items-center">
              <svg class="w-5 h-5 mr-2 text-[#C1272D]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              {t('products_services.education.items.k12.title')}
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 mr-2 text-[#C1272D]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              {t('products_services.education.items.university.title')}
            </li>
          </ul>
          <div class="flex justify-between">
            <a 
              href={`/${lang}/education-sms-solution`}
              class="text-sm text-[#C1272D] hover:text-[#991B1F] transition-colors duration-300"
            >
              Wiki School →
            </a>
            <a 
              href={`/${lang}/education-ums-solution`}
              class="text-sm text-[#C1272D] hover:text-[#991B1F] transition-colors duration-300"
            >
              Wiki College →
            </a>
          </div>
        </div>
      </div>

      <!-- Vithean -->
      <div class="bg-white shadow-lg rounded-xl overflow-hidden hover:shadow-xl transition-shadow duration-300">
        <div class="aspect-w-16 aspect-h-9">
          <img 
            src="/images/vithean-solution.jpg" 
            alt="Vithean Solution" 
            class="w-full h-48 object-cover"
          />
        </div>
        <div class="p-6">
          <h4 class="text-xl font-semibold mb-3 text-[#C1272D]">{t('products_services.enterprise.items.vithean.title')}</h4>
          <p class="text-gray-600 mb-4">
            {t('products_services.enterprise.items.vithean.description')}
          </p>
          <a 
            href={`/${lang}/accounting-erp-vithean`}
            class="inline-block text-[#C1272D] font-semibold hover:text-[#991B1F] transition-colors duration-300"
          >
            {t('common.buttons.learn_more')} →
          </a>
        </div>
      </div>

      <!-- Bakan Elite -->
      <div class="bg-white shadow-lg rounded-xl overflow-hidden hover:shadow-xl transition-shadow duration-300">
        <div class="aspect-w-16 aspect-h-9">
          <img 
            src="/images/bakan-elite.jpg" 
            alt="Bakan Elite" 
            class="w-full h-48 object-cover"
          />
        </div>
        <div class="p-6">
          <h4 class="text-xl font-semibold mb-3 text-[#C1272D]">{t('bakan_elite.title')}</h4>
          <p class="text-gray-600 mb-4">
            {t('bakan_elite.subtitle')}
          </p>
          <a 
            href={`/${lang}/bakan-elite`}
            class="inline-block text-[#C1272D] font-semibold hover:text-[#991B1F] transition-colors duration-300"
          >
            {t('common.buttons.learn_more')} →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Impact Section -->
  <section id="impact" class="bg-red-50 py-16">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h3 class="text-2xl font-bold mb-10 text-[#C1272D]">{t('home.impact.title')}</h3>
      <div class="grid md:grid-cols-3 gap-6">
        <div>
          <p class="text-4xl font-bold text-[#C1272D]">25+</p>
          <p class="text-sm">{t('home.impact.government_partners')}</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-[#C1272D]">3M+</p>
          <p class="text-sm">{t('home.impact.users_engaged')}</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-[#C1272D]">99.9%</p>
          <p class="text-sm">{t('home.impact.system_uptime')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Industries Section -->
  <section id="industries" class="py-16 max-w-7xl mx-auto px-4">
    <h3 class="text-2xl font-bold mb-10 text-center text-[#C1272D]">{t('home.industries.title')}</h3>
    <div class="grid md:grid-cols-4 gap-6 text-center">
      <div><p class="font-medium">🎓 {t('home.industries.education')}</p></div>
      <div><p class="font-medium">🏛 {t('home.industries.government')}</p></div>
      <div><p class="font-medium">💼 {t('home.industries.enterprise')}</p></div>
      <div><p class="font-medium">🏥 {t('home.industries.healthcare')}</p></div>
    </div>
  </section>

  <!-- Company Section -->
  <section id="company" class="bg-red-50 py-16">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h3 class="text-2xl font-bold mb-6 text-[#C1272D]">{t('home.about.title')}</h3>
      <p class="text-gray-700 max-w-2xl mx-auto mb-6">{t('home.about.description')}</p>
      <a 
        href={`/${lang}/about/`}
        class="text-[#C1272D] underline hover:text-[#991B1F] transition-colors duration-300"
      >
        {t('common.buttons.learn_more')} →
      </a>
    </div>
  </section>

  <!-- Blogs Section -->
  <section id="blogs" class="py-16 max-w-7xl mx-auto px-4">
    <h3 class="text-2xl font-bold mb-10 text-center text-[#C1272D]">{t('home.blogs.title')}</h3>
    <div class="grid md:grid-cols-3 gap-6">
      {blogItems.map((blog) => (
        <div class="bg-white shadow rounded-xl p-6">
          <p class="text-xs text-gray-400 mb-1">{blog.date} • {blog.author}</p>
          <h4 class="font-semibold text-[#C1272D] mb-2">{blog.title}</h4>
          <p class="text-sm text-gray-600">{blog.description}</p>
          <a 
            href={blog.link}
            class="text-sm text-[#C1272D] mt-2 inline-block hover:text-[#991B1F] transition-colors duration-300"
          >
            {t('common.buttons.read_more')} →
          </a>
        </div>
      ))}
    </div>
    <div class="text-right mt-8">
      <a 
        href={`/${lang}/blogs`}
        class="inline-block text-[#C1272D] font-semibold hover:text-[#991B1F] transition-colors duration-300"
      >
        {t('common.buttons.explore_more')} →
      </a>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="bg-red-50 py-16 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h3 class="text-2xl font-bold mb-4 text-[#C1272D]">{t('home.contact.title')}</h3>
      <p class="text-gray-700 mb-6">{t('home.contact.description')}</p>
      <a 
        href={`/${lang}/contact/`}
        class="bg-[#C1272D] text-white px-6 py-3 rounded-full hover:bg-[#991B1F] transition-colors duration-300"
      >
        {t('common.buttons.contact_us')}
      </a>
    </div>
  </section>
</Base> 