---
import Base from '../../layouts/Base.astro';
import { getLangFromUrl, useTranslations, getContentTranslations } from '../../i18n/utils';
import { ui } from '../../i18n/ui';
import blogData from '../../data/blog.json';

export async function getStaticPaths() {
  return Object.keys(ui).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const content = await getContentTranslations(lang);
const { posts } = blogData;
---

<Base>
  <!-- Blogs Header -->
  <section class="bg-slate-600 text-white py-16 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">{content.home.blogs.title}</h1>
      <p class="text-lg md:text-xl mb-8">{content.home.blogs.subtitle}</p>
    </div>
  </section>

  <!-- Blog Posts Grid -->
  <section class="py-16 bg-white text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto max-w-6xl">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <article class="bg-white rounded-lg shadow-md overflow-hidden">
            <img 
              src={`/images/blog-${post.link.split('/').pop()}.jpg`} 
              alt={post.title} 
              class="w-full h-48 object-cover" 
            />
            <div class="p-6">
              <div class="flex items-center text-sm text-gray-600 mb-4">
                <span>{post.date}</span>
                <span class="mx-2">•</span>
                <span>{post.author}</span>
              </div>
              <h3 class="text-xl font-semibold mb-2">{post.title}</h3>
              <p class="text-gray-600 mb-4">{post.description}</p>
              <a 
                href={`/${lang}${post.link}`}
                class="text-slate-600 font-semibold hover:text-slate-800 inline-flex items-center"
              >
                {t('common.buttons.read_more')}
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter Section -->
  <section class="py-16 bg-gray-100 text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-bold mb-8">{content.home.blogs.newsletter.title}</h2>
      <p class="text-lg mb-8">{content.home.blogs.newsletter.subtitle}</p>
      <form class="max-w-md mx-auto">
        <div class="flex gap-4">
          <input
            type="email"
            placeholder={content.home.blogs.newsletter.email_placeholder}
            class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            required
          />
          <button
            type="submit"
            class="bg-slate-600 text-white py-2 px-6 rounded-lg font-semibold hover:bg-slate-700 transition-colors duration-300"
          >
            {content.home.blogs.newsletter.subscribe_button}
          </button>
        </div>
      </form>
    </div>
  </section>
</Base>
