---
import Base from '../../layouts/Base.astro';
import { getLangFromUrl, useTranslations, getContentTranslations } from '../../i18n/utils';
import { ui } from '../../i18n/ui';

export async function getStaticPaths() {
  return Object.keys(ui).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const content = await getContentTranslations(lang);
---

<Base>
  <!-- Blogs Header -->
  <section class="bg-slate-600 text-white py-16 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Latest News & Updates</h1>
      <p class="text-lg md:text-xl mb-8">Stay informed about our latest developments and industry insights</p>
    </div>
  </section>

  <!-- Blog Posts Grid -->
  <section class="py-16 bg-white text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto max-w-6xl">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Blog Post Card 1 -->
        <article class="bg-white rounded-lg shadow-md overflow-hidden">
          <img src="/images/blog-1.jpg" alt="Blog Post 1" class="w-full h-48 object-cover" />
          <div class="p-6">
            <h3 class="text-xl font-semibold mb-2">Digital Transformation in Education</h3>
            <p class="text-gray-600 mb-4">Exploring the impact of technology on modern education systems...</p>
            <a href="#" class="text-slate-600 font-semibold hover:text-slate-800">Read More →</a>
          </div>
        </article>

        <!-- Blog Post Card 2 -->
        <article class="bg-white rounded-lg shadow-md overflow-hidden">
          <img src="/images/blog-2.jpg" alt="Blog Post 2" class="w-full h-48 object-cover" />
          <div class="p-6">
            <h3 class="text-xl font-semibold mb-2">HR Management Best Practices</h3>
            <p class="text-gray-600 mb-4">Essential strategies for effective human resource management...</p>
            <a href="#" class="text-slate-600 font-semibold hover:text-slate-800">Read More →</a>
          </div>
        </article>

        <!-- Blog Post Card 3 -->
        <article class="bg-white rounded-lg shadow-md overflow-hidden">
          <img src="/images/blog-3.jpg" alt="Blog Post 3" class="w-full h-48 object-cover" />
          <div class="p-6">
            <h3 class="text-xl font-semibold mb-2">ERP Implementation Guide</h3>
            <p class="text-gray-600 mb-4">Step-by-step guide to successful ERP system implementation...</p>
            <a href="#" class="text-slate-600 font-semibold hover:text-slate-800">Read More →</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Newsletter Section -->
  <section class="py-16 bg-gray-100 text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-bold mb-8">Subscribe to Our Newsletter</h2>
      <p class="text-lg mb-8">Stay updated with our latest news and insights</p>
      <form class="max-w-md mx-auto">
        <div class="flex gap-4">
          <input
            type="email"
            placeholder="Enter your email"
            class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            required
          />
          <button
            type="submit"
            class="bg-slate-600 text-white py-2 px-6 rounded-lg font-semibold hover:bg-slate-700 transition-colors duration-300"
          >
            Subscribe
          </button>
        </div>
      </form>
    </div>
  </section>
</Base>
