---
import Base from "../../../layouts/Base.astro";

// Fetch all blog posts
export async function getStaticPaths() {
  const allPosts = await Astro.glob('../../content/blog/en/*.md');
  return allPosts.map((post) => {
    const slug = post.file.split('/').pop().replace('.md', ''); // Extract slug
    return { params: { slug } };
  });
}

// Get the current slug and fetch the corresponding post
const { slug } = Astro.params;
const allPosts = await Astro.glob('../../content/blog/en/*.md');
const post = allPosts.find((p) => p.file.includes(`${slug}.md`));

if (!post) {
  throw new Error(`Post not found for slug: ${slug}`);
}
---

<Base pageTitle={post.frontmatter.title}>
  <section class="bg-gray-50 py-12">
    <div class="max-w-6xl mx-auto px-6">
      <h1 class="text-5xl font-bold text-gray-800 mb-4">{post.frontmatter.title}</h1>
      <p class="text-gray-500 text-sm mb-4">{post.frontmatter.date}</p>
      <div class="prose lg:prose-xl" set:html={post.compiledContent()}></div>
    </div>
  </section>
</Base>