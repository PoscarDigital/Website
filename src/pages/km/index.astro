---
// src/pages/index.astro
import Base from "../../layouts/Base.astro";
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

---
<Base>
  <section class="bg-slate-600 text-white py-16">
    <div class="container mx-auto text-center">
      <h1 class="text-5xl font-extrabold mb-4">Poscar Digital</h1>
      <p class="text-xl mb-8">бһҹбҹ’бһңбҹӮбһ„бһҡбһҖбһ•бһӣбһ·бһҸбһ•бһӣ бһ“бһ·бһ„бһҹбҹҒбһңбһ¶бһҖбһҳбҹ’бһҳбһҡбһ”бһҹбҹӢбһҷбһҫбһ„бһҠбҹӮбһӣбһ”бһ¶бһ“бһҡбһ…бһ“бһ¶бһЎбһҫбһ„бһҠбһҫбһҳбҹ’бһ”бһёбһ”бҹҶбһ–бҹҒбһүбһҸбһ¶бһҳбһҸбҹҶбһҡбһјбһңбһҖбһ¶бһҡ бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбҹ”</p>
      <a
        href={`/${lang}/product_services/`} 
        class="bg-transparent border-2 border-white text-white py-3 px-6 rounded-lg text-lg font-semibold hover:bg-white hover:text-slate-600 transition-colors duration-300"
      >
        бһ…бһ¶бһ”бҹӢбһ•бҹ’бһҸбһҫбһҳ
      </a>
    </div>
  </section>

  <section class="py-16 bg-white text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto grid grid-cols-1 md:grid-cols-2 gap-12">
      
      <!-- бһ•бҹ’бһ“бҹӮбһҖбһўбһҸбҹ’бһҗбһ”бһ‘: бһўбҹҶбһ–бһёбһҷбһҫбһ„ (бһ“бҹ…бһҒбһ¶бһ„бһҶбҹ’бһңбҹҒбһ„) -->
      <div class="text-center md:text-left">
        <h2 class="text-3xl md:text-4xl font-semibold mb-6">бһўбҹҶбһ–бһёбһҷбһҫбһ„</h2>
        <p class="text-lg md:text-xl mb-8">
          бһҳбһҫбһӣбһҡбһҝбһ„бһҡбһ”бһҹбҹӢбһҷбһҫбһ„ бһ бһҫбһҷбһҳбһҫбһӣбһғбһҫбһүбһўбҹ’бһңбһёбһҠбҹӮбһӣбһҮбһ¶бһҖбҹҶбһӣбһ¶бҹҶбһ„бһ’бҹ’бһңбһҫбһұбҹ’бһҷбһҷбһҫбһ„бһ”бҹ’бһҡбһҫбһ”бҹ’бһҡбһ¶бһҹбҹӢбһҖбһ¶бһҡбһ”бһ„бҹ’бһҖбһҫбһҸбһ“бһ·бһ„бһ…бҹ’бһ“бҹғбһ”бҹ’бһҡбһҢбһ·бһҸбҹ”
        </p>
        <div class="text-center md:text-left">
          <h2 class="text-1xl md:text-2xl font-semibold mb-6">бһҳбһҫбһӣбһ‘бһҹбҹ’бһҹбһ“бҹҲ</h2>
          <p class="text-lg md:text-xl mb-8">
            Lorem ipsum dolor sit amet, consectetur adipisicing elit. Facere ipsa exercitationem laudantium ab ratione! Debitis voluptatum esse mollitia itaque porro, non nihil! Ullam veniam, temporibus officiis delectus doloribus recusandae sapiente!
          </p>
        </div>
      </div>
  
      <!-- бһ•бҹ’бһ“бҹӮбһҖбһңбһёбһҠбҹҒбһўбһј: бһңбһёбһҠбҹҒбһўбһј YouTube (бһ“бҹ…бһҒбһ¶бһ„бһҹбҹ’бһҸбһ¶бҹҶ) -->
      <div class="flex justify-center items-center shadow-xl">
        <div class="w-full max-w-3xl">
          <!-- iframe бһ”бһ¶бһ“бһҖбҹҶбһҺбһҸбҹӢбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһңбһёбһҠбҹҒбһўбһјбһ’бҹҶбһҮбһ¶бһ„бһҳбһ»бһ“ -->
          <iframe
            class="w-full h-[400px] md:h-[300px]"
            src="https://www.youtube.com/embed/SUGhEr_7B3c"
            title="бһңбһёбһҠбҹҒбһўбһј бһ‘бһҹбҹ’бһҹбһ“бҹҲбһҡбһ”бһҹбҹӢбһҷбһҫбһ„"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen>
          </iframe>
        </div>
      </div>
    </div>
  </section>
  

  <!-- бһ•бҹ’бһ“бҹӮбһҖбһ•бһӣбһ·бһҸбһ•бһӣ бһ“бһ·бһ„бһҹбҹҒбһңбһ¶бһҖбһҳбҹ’бһҳбһҠбҹӮбһӣбһҳбһ¶бһ“бһӣбһҖбҹ’бһҒбһҺбҹҲбһ–бһ·бһҹбҹҒбһҹ -->
  <section class="py-16 bg-gray-100 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-semibold mb-6">
        бһ•бһӣбһ·бһҸбһ•бһӣ бһ“бһ·бһ„бһҹбҹҒбһңбһ¶бһҖбһҳбҹ’бһҳбһҠбҹӮбһӣбһҳбһ¶бһ“бһӣбһҖбҹ’бһҒбһҺбҹҲбһ–бһ·бһҹбҹҒбһҹ
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- бһ§бһ‘бһ¶бһ бһҡбһҺбҹҚбһҹбҹҖбһңбһ—бҹ…бһ•бһӣбһ·бһҸбһ•бһӣ/бһҹбҹҒбһңбһ¶бһҖбһҳбҹ’бһҳ -->
        <div class="bg-white shadow-xl rounded-lg p-6">
          <h3 class="text-2xl font-semibold mb-4">Kindergarten & K12</h3>
          <p class="text-lg mb-4">
            бһ•бҹ’бһҸбһӣбҹӢбһҖбһ¶бһҡбһўбһ”бҹӢбһҡбҹҶбһӮбһ»бһҺбһ—бһ¶бһ–бһ…бһ¶бһ”бҹӢбһ–бһёбһҗбҹ’бһ“бһ¶бһҖбҹӢбһҖбһ»бһҳбһ¶бһҡ бһҸбһ¶бһҳбһҡбһҷбҹҲбһҖбһҳбҹ’бһҡбһ·бһҸ K12бҹ”
          </p>
          <a
            href={`/${lang}/product-services/`} 
            class="text-red-600 font-semibold hover:underline transition-colors duration-300"
          >
            бһҡбҹҖбһ“бһ”бһ“бҹ’бһҗбҹӮбһҳ
          </a>
        </div>
        <div class="bg-white shadow-xl rounded-lg p-6">
          <h3 class="text-2xl font-semibold mb-4">University Solutions</h3>
          <p class="text-lg mb-4">
            бһҮбҹҶбһҡбһ»бһүбһҖбһ¶бһҡбһўбһ”бҹӢбһҡбҹҶбһҒбҹ’бһ–бһҹбҹӢбһҠбҹ„бһҷбһҠбҹҶбһҺбҹ„бҹҮбһҹбҹ„бһ”бһүбҹ’бһүбһ¶бҹ”
          </p>
          <a
            href={`/${lang}/product-services/`} 
            class="text-red-600 font-semibold hover:underline transition-colors duration-300"
          >
            бһҡбҹҖбһ“бһ”бһ“бҹ’бһҗбҹӮбһҳ
          </a>
        </div>
        <div class="bg-white shadow-xl rounded-lg p-6">
          <h3 class="text-2xl font-semibold mb-4">HRM Solutions</h3>
          <p class="text-lg mb-4">
            бһ”бһҳбҹ’бһӣбҹӮбһ„бһҖбһ¶бһҡбһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһ’бһ“бһ’бһ¶бһ“бһҳбһ“бһ»бһҹбҹ’бһҹбһҮбһ¶бһҳбһҪбһҷбһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶бһҶбҹ’бһӣбһ¶бһҸбһңбҹғбҹ”
          </p>
          <a
            href={`/${lang}/product-services/`} 
            class="text-red-600 font-semibold hover:underline transition-colors duration-300"
          >
            бһҡбҹҖбһ“бһ”бһ“бҹ’бһҗбҹӮбһҳ
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- бһ•бҹ’бһ“бҹӮбһҖбһўбҹҶбһ–бһёбһҖбһ¶бһҡбһ‘бҹҶбһ“бһ¶бһҖбҹӢбһ‘бҹҶбһ“бһ„ -->
  <section class="py-16 text-black text-center px-6 md:px-12 lg:px-16">
    <div class="container mx-auto">
      <h2 class="text-3xl md:text-4xl font-semibold mb-4">
        бһ‘бҹҶбһ“бһ¶бһҖбҹӢбһ‘бҹҶбһ“бһ„бһҮбһ¶бһҳбһҪбһҷбһҷбһҫбһ„
      </h2>
      <p class="text-lg md:text-xl mb-6">
        бһҳбһ¶бһ“бһҹбҹҶбһҺбһҪбһҡбһ¬бһҸбҹ’бһҡбһјбһңбһҖбһ¶бһҡбһҮбҹҶбһ“бһҪбһҷ? бһҷбһҫбһ„бһ“бҹ…бһ‘бһёбһ“бҹҒбҹҮбһҠбһҫбһҳбҹ’бһ”бһёбһҮбһҪбһҷ!
      </p>
      <a
      href={`/${lang}/contact/`} 
        class="border-2 border-slate-600  text-slate-600 py-3 px-8 rounded-lg text-lg font-semibold hover:bg-slate-600 hover:text-white transition-colors duration-300"
      >
        бһ‘бҹҶбһ“бһ¶бһҖбҹӢбһ‘бҹҶбһ“бһ„
      </a>
    </div>
  </section>
</Base>
